<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="fund_movement_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="text-center" style="border-top:1px solid black;border-bottom:1px solid black;">
                                <h3>FUND MOVEMENT/INCOME STATEMENT</h3>
                            </div>
                            <div class="text-center">
                                <h5>
                                    Reporting Date:
                                    <t t-esc="reporting_date"/>
                                </h5>
                            </div>
                            <div class="text-center">
                                <h5>
                                    Investment Admin:
                                    <t t-esc="data['form']['investment_adm']"/>
                                </h5>
                            </div>
                            <div class="row" width="100%" style="margin-top: 15px;">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th width="50%">Account Code</th>
                                            <th width="25%">Debit</th>
                                            <th width="25%">Credit</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="lines" t-as="line">
                                            <td>
                                                <t t-esc="line.code_id.name"/>
                                            </td>
                                            <td>
                                                <t t-esc="line.debit"/>
                                            </td>
                                            <td>
                                                <t t-esc="line.price_cost"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="clearfix mb-4">
                                <div id="total" class="row">
                                    <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto">
                                        <table class="table table-sm table-borderless" style="page-break-inside: avoid;">
                                            <tr>
                                                <td>Total Debit: </td>
                                                <td><t t-esc="debit"/></td>
                                            </tr>
                                            <tr>
                                                <td>Total Credit: </td>
                                                <td><t t-esc="credit"/></td>
                                            </tr>
                                            <tr>
                                                <td>Total Balance: </td>
                                                <td><t t-esc="balance"/></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>