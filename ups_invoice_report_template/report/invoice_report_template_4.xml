<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="custom_invoice_report_4">
        <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
            <t t-set="primary" t-value="res_company.invoice_primary_color or ''"/> 
            <t t-set="header" t-value="res_company.invoice_header_color or ''"/>  
            <t t-set="secondary" t-value="res_company.invoice_secondary_color or ''"/> 
            
            <t t-set="r" t-value="int((header or '#89492c')[1:3], 16)"/>
            <t t-set="g" t-value="int((header or '#89492c')[3:5], 16)"/>
            <t t-set="b" t-value="int((header or '#89492c')[5:7], 16)"/>
            
            <t t-set="r1" t-value="int((secondary or '#89492c')[1:3], 16)"/>
            <t t-set="g1" t-value="int((secondary or '#89492c')[3:5], 16)"/>
            <t t-set="b1" t-value="int((secondary or '#89492c')[5:7], 16)"/>

            <t t-set="o" t-value="doc.with_context(lang=lang)"/>
            
            <t t-set="th_bg" t-value="'rgba(%s, %s, %s, 0.3)' % (r, g, b) if header else '#89492c'"/>
            <t t-set="th_bg2" t-value="'rgba(%s, %s, %s, 0.3)' % (r1, g1, b1) if secondary else '#89492c'"/>



            <div class="page invoice_page_4">

                <div class="inv-header" t-attf-style="background-color: {{ secondary or '#89492c' }} !important; color: #ffffff !important;">
    <table class="w-100 header_table_layout table-borderless">
        <tr>
            <td class="brand_col">
                <div class="logo_frame">
                    <img t-if="o.company_id.logo" 
                         t-att-src="image_data_uri(o.company_id.logo)" 
                         alt="Company Logo"/>
                </div>
                
                <div class="company_name_title" t-field="o.company_id.name"/>
                
                <div class="state_header_container">
                    <div class="status-container">
                        <span t-if="o.state == 'draft'" class="status-badge state-draft">DRAFT</span>
                        <span t-if="o.state == 'posted'" class="status-badge state-posted">POSTED</span>
                        <span t-if="o.state == 'cancel'" class="status-badge state-cancel">CANCELLED</span>
                        <span t-if="o.state not in ['draft', 'posted', 'cancel']" class="status-badge state-default" t-field="o.state"/>
                    </div>
                </div>
            </td>

            <td class="meta_col text-end">
                <h2 class="inv_label">INVOICE</h2>
                <div class="meta_info_card">
                    <div class="inv_id">
                        <span class="prefix">NO.</span>
                        <span t-field="o.name"/>
                    </div>
                    <div class="date_grid">
                        <p>Date: <span t-field="o.invoice_date" t-options='{"widget": "date", "format": "dd MMM yyyy"}'/></p>
                        <p class="due_line">Due: <span t-field="o.invoice_date_due" t-options='{"widget": "date", "format": "dd MMM yyyy"}'/></p>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</div>

                <div class="row inv-party">
                    <div class="col-6 left-party-col">
                        <h6 class="section-label" t-attf-style="color: {{ secondary or '#ffffff' }}; background-color: {{ th_bg2 }} !important;">Supplier</h6>
                        <strong t-field="o.company_id.name"/>
                        <div t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        <t t-if="o.company_id.phone"><div><strong>Tel:</strong> <span t-field="o.company_id.phone"/></div></t>
                        <t t-if="o.company_id.email"><div><strong>Email:</strong> <span t-field="o.company_id.email"/></div></t>
                    </div>

                    <div class="col-6 party-col">
                        <h6 class="section-label" t-attf-style="color: {{ secondary or '#ffffff' }}; background-color: {{ th_bg2 }} !important;">Invoice To</h6>
                        <strong t-field="o.partner_id.name"/>
                        <div t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        <t t-if="o.partner_id.vat">
                            <div><strong>GSTIN:</strong> <span t-field="o.partner_id.vat"/></div>
                        </t>
                        <t t-if="o.l10n_in_state_id.name">
                            <div><strong>Place of Supply:</strong> <span t-field="o.l10n_in_state_id.name"/></div>
                        </t>
                    </div>
                </div>

                <table class="table inv-table table-borderless">
                    <thead>
                        <tr>
                            <th t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Item Description</th>
                            <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">HSN/SAC</th>
                            <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Qty</th>
                            <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Price</th>
                            <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Taxes</th>
                            <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Taxable Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr t-attf-style="background-color: {{ (line_index % 2 != 0) and ('rgba(%s, %s, %s, 0.1)' % (r, g, b)) or 'transparent' }} !important;">
                                <td><span t-field="line.name"/></td>
                                <td class="text-center"><span t-field="line.l10n_in_hsn_code"/></td>
                                <td class="text-center"><span t-field="line.quantity"/></td>
                                <td class="text-center"><span t-field="line.price_unit"/></td>
                                <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                                <td class="text-center"><span t-field="line.price_subtotal"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div class="row mt-4">
                    <div class="col-6 terms-col">
                        <t t-if="o.narration">
                            <h6 class="section-label" t-attf-style="color: {{ secondary or '#ffffff' }}; background-color: {{ th_bg2 }} !important;">Terms &amp; Conditions</h6>
                            <div class="terms-box"><t t-esc="o.narration"/></div>
                        </t>
                    </div>
                    <div class="col-6">
                        <table class="table totals-table table-borderless">
                            <tr>
                                <td><strong>Untaxed</strong></td>
                                <td class="text-end"><span t-field="o.amount_untaxed"/></td>
                            </tr>
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                    <tr>
                                        <td t-esc="tax_group['group_name']"/>
                                        <td class="text-end" t-esc="tax_group['tax_amount_currency']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </tr>
                                </t>
                            </t>
                            <tr class="grand-total-row">
                                <td><h6><strong>Total</strong></h6></td>
                                <td class="text-end"><h6 t-field="o.amount_total"/></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <h5 class="mt-4">HSN/SAC Summary</h5>
                <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
                        <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" class="mt-3">
                                        <table class="inv-table table-sm table-borderless col-6">
                                            <thead>
                                                <th t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">HSN/SAC</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Quantity</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Rate %</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">Taxable Value</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">SGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">CGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">IGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="color: {{ header or '#ffffff' }}; background-color: {{ th_bg }} !important;">CESS</th>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item" t-attf-style="background-color: {{ (line_index % 2 != 0) and ('rgba(%s, %s, %s, 0.1)' % (r, g, b)) or 'transparent' }} !important;">
                                                <td t-esc="item['l10n_in_hsn_code']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>

                <div class="payment-summary-grid">
                    <div class="row g-0 border-bottom">
                        <div class="col-6 summary-box border-end">
                            <span class="summary-label" t-attf-style="color: {{primary or '#242e3b'}}">Payment Terms</span>
                            <div class="summary-value"><span t-field="o.invoice_payment_term_id"/></div>
                        </div>
                        <div class="col-6 summary-box">
                            <span class="summary-label" t-attf-style="color: {{primary or '#242e3b'}}">Payment Reference</span>
                            <div class="summary-value"><span t-field="o.payment_reference"/></div>
                        </div>
                    </div>
                    <div class="row g-0">
                        <div class="col-6 summary-box border-end">
                            <span class="summary-label" t-attf-style="color: {{primary or '#242e3b'}}">Total in Words</span>
                            <div class="summary-value text-wrap"><span t-esc="o.currency_id.amount_to_text(o.amount_total)"/></div>
                        </div>
                        <div class="col-6 summary-box" t-attf-style="background-color: rgba({{ r2 }}, {{ g2 }}, {{ b2 }}, 0.15) !important;">
                            <span class="summary-label" t-attf-style="color: {{primary or '#242e3b'}}">Taxable Value</span>
                            <div class="summary-value fw-bold fs-5 text-navy">
                                <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_invoice_4">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_4"/>
            </t>
        </t>
    </template>

</odoo>
