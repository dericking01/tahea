<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="custom_invoice_report_7">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '#002E5D'"/> 
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '#F4F7F9'"/>  
        <t t-set="header" t-value="res_company.invoice_header_color or '#002E5D'"/> 
        
        <t t-set="r" t-value="int((header or '#002E5D')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#002E5D')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#002E5D')[5:7], 16)"/>
        <t t-set="row_bg" t-value="'rgba(%s, %s, %s, 0.1)' % (r, g, b)"/>

        <t t-set="o" t-value="doc.with_context(lang=lang)" />
        <div class="page invoice_page_7">
            
            <div class="row g-0 header-box">
                <div class="col-6 left-panel" t-attf-style="background-color: {{ primary }} !important;">
                    <div class="invoice-title-box">

                        <div class="logo-container">
                            <div class="logo-box">
                                <img t-if="res_company.logo" 
                                    t-att-src="image_data_uri(res_company.logo)" 
                                    alt="Logo"/>
                            </div>
                        </div>

                        

                        <h1 class="doc-title" style="color: #FFFFFF !important;">INVOICE</h1>
                       <table class="meta-info-table table-borderless" width="100%">
                            <tr>
                                <td class="meta-cell">
                                    <span class="label">Invoice No</span><br/>
                                    <span class="value" t-field="o.name"/>
                                </td>
                                <td class="meta-cell">
                                    <span class="label">Invoice Date</span><br/>
                                    <span class="value" t-field="o.invoice_date" t-options='{"widget": "date"}'/>
                                </td>
                            </tr>
                            <tr>
                                <td class="meta-cell">
                                    <span class="label">Due Date</span><br/>
                                    <span class="value" t-field="o.invoice_date_due" t-options='{"widget": "date"}'/>
                                </td>
                                <td class="meta-cell">
                                    <span class="label">State</span><br/>
                                    <div class="status-pill-wrapper">
                                        <span t-attf-class="status-pill-style #{'status-posted' if o.state == 'posted' else 'status-draft' if o.state == 'draft' else 'status-cancel' if o.state == 'cancel' else 'status-proforma' if o.state == 'proforma' else 'status-default'}"
                                            t-field="o.state"/>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

               <div class="col-6 right-panel" t-attf-style="background-color: {{ secondary }} !important;">
                   <table class="address-table table-borderless" width="100%">
                        <tr>
                            <td class="address-cell">
                                <h6 t-attf-style="color: {{ primary }};">Bill From</h6>
                                <div class="details"
                                    t-field="o.company_id.partner_id"
                                    t-options='{"widget": "contact", "fields": ["name", "address", "phone"], "no_marker": True}'/>
                            </td>

                            <td class="address-divider"></td>

                            <td class="address-cell">
                                <h6 t-attf-style="color: {{ primary }};">Bill To</h6>
                                <div class="details"
                                    t-field="o.partner_id"
                                    t-options='{"widget": "contact", "fields": ["name", "address", "phone"], "no_marker": True}'/>
                            </td>
                        </tr>
                    </table>


                    <div class="extra-info-wrapper">
                        <div class="extra-info" t-if="o.partner_id.vat">
                            <strong t-attf-style="color: {{ primary }};">GSTIN:</strong>
                            <span t-field="o.partner_id.vat"/>
                        </div>

                        <div class="extra-info" t-if="o.l10n_in_state_id">
                            <strong t-attf-style="color: {{ primary }};">Place of Supply:</strong>
                            <span t-field="o.l10n_in_state_id.name"/>
                        </div>
                    </div>

                </div>

            </div>

            <div>
                <table class="table table-custom mt-4 table-borderless">
                    <thead>
                        <tr>
                            <th class="text-start" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Description</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">HSN/SAC</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Price</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Qty</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Taxes</th>
                            <th class="text-end" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.invoice_line_ids" t-as="line" t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                            <td class="text-start"><span t-field="line.name"/></td>
                            <td class="text-center"><span t-field="line.product_id.l10n_in_hsn_code"/></td>
                            <td class="text-center"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                            <td class="text-center"><span t-field="line.quantity"/></td>
                            <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                            <td class="text-end fw-bold"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                        </tr>
                    </tbody>
                </table>

               <div class="row">
                    <div class="col-6 terms-col">
                        <h6 class="fw-bold" t-attf-style="color: {{ primary }};">Terms &amp; Conditions</h6>
                        <p class="small text-muted" t-field="o.narration"/>
                    </div>
                    <div class="col-6">
                        <table class="table table-borderless float-end summary-table">
                            <tr>
                                <td class="text-muted">Subtotal</td>
                                <td class="text-end"><span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                            </tr>
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                    <tr>
                                        <td t-esc="tax_group['group_name']"/>
                                        <td class="text-end" t-esc="tax_group['tax_amount_currency']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </tr>
                                </t>
                            </t>
                            <tr class="total-row-highlight" t-attf-style="border-top: 2px solid {{ primary }};">
                                <td class="fw-bold" t-attf-style="color: {{ primary }};">Grand Total</td>
                                <td class="text-end fw-bold h4" t-attf-style="color: {{ primary }};">
                                    <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="footer-design" t-attf-style="background-color: {{ header }} !important;">
                    <div class="shape-circle-main" t-attf-style="background-color: {{ primary }} !important;"></div>
                    <div class="shape-circle-alt" t-attf-style="background-color: {{ primary }} !important;"></div>
                    <div class="payment-card-overlay">
                        <h6 class="footer-title">Payment Details</h6>
                        <table class="payment-table-grid">
                            <tr>
                                <td width="50%" class="p-cell">
                                    <small style="color: rgba(255,255,255,0.6);">Reference</small><br/>
                                    <span class="text-white" t-esc="o.payment_reference"/>
                                </td>
                                <td width="50%" class="p-cell border-left">
                                    <small style="color: rgba(255,255,255,0.6);">Amount in Words</small><br/>
                                    <span class="text-white" t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                                </td>
                            </tr>
                            <tr>
                                <td width="50%" class="p-cell border-top">
                                    <small style="color: rgba(255,255,255,0.6);">Payment Terms</small><br/>
                                    <span class="text-white" t-esc="o.invoice_payment_term_id.name"/>
                                </td>
                                <td width="50%" class="p-cell border-top border-left highlight-cell">
                                    <small style="color: rgba(255,255,255,0.8);">Total Payable</small><br/>
                                    <span class="total-value-footer" t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
            </div>

            <h5 class="mt-4" t-attf-style="color: {{ primary }};">HSN/SAC Summary</h5>
            <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
            <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" class="mt-3">
                                        <table class="table table-custom mt-4 table-borderless">
                                            <thead>
                                                <th t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">HSN/SAC</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Quantity</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Rate %</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">Taxable Value</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">SGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">CGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">IGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">CESS</th>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item" t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                                                <td t-esc="item['l10n_in_hsn_code']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>
        </div>
    </t>
</template>


    <template id="report_invoice_7">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_7"/>
            </t>
        </t>
    </template>

</odoo>
