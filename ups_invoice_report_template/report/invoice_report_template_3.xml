<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="custom_invoice_report_3">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '#0a4a5a'"/> 
        <t t-set="header" t-value="res_company.invoice_header_color or '#0a4a5a'"/>  
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '#EBE7E2'"/> 
        <t t-set="r" t-value="int((secondary or '#EBE7E2')[1:3], 16)"/>
        <t t-set="g" t-value="int((secondary or '#EBE7E2')[3:5], 16)"/>
        <t t-set="b" t-value="int((secondary or '#EBE7E2')[5:7], 16)"/>
        <t t-set="th_bg" t-value="'rgba(%s, %s, %s, 0.3)' % (r, g, b)"/>
        <t t-set="o" t-value="doc.with_context(lang=lang)" />
        
        <div class="page invoice_page_3">
            <div class="top-bar-navy mb-4">
        <table class="layout-table table-borderless">
            <tr>
                <td class="bar-thick" t-attf-style="background-color: {{ primary }} !important;"></td>
                <td class="bar-text" t-attf-style="color: {{ primary }};">
                    INVOICE 
                </td>
                <td class="bar-thick" t-attf-style="background-color: {{ primary }} !important;"></td>
            </tr>
        </table>
    </div>

        <div class="header-logo-container text-end mb-3">
            <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 45px; width: auto;"/>
        </div>

                
            <table class="w-100 mb-5 header-table table-borderless">
        <tr>
            <td class="party-col">
                <div class="section-label">Supplier</div>
                <h2 class="brand-name" t-field="o.company_id.name" t-attf-style="color: {{ primary }};"/>
                <div class="contact-details">
                    <div t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    <div class="mt-2">
                        <strong>Tel:</strong> <span t-field="o.company_id.phone"/><br/>
                        <strong>Email:</strong> <span t-field="o.company_id.email"/>
                    </div>
                </div>
            </td>

            <td class="party-col ps-4">
                <div class="section-label">Invoice To</div>
                <h2 class="brand-name" t-field="o.partner_id.name" t-attf-style="color: {{ primary }};"/>
                <div class="contact-details">
                    <div t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    <div class="mt-2" t-if="o.partner_id.vat">
                        <strong>GSTIN:</strong> <span t-field="o.partner_id.vat"/><br/>
                        <strong>State:</strong> <span t-field="o.partner_id.state_id.name"/>
                    </div>
                </div>
            </td>

            <td class="meta-col">
                <div class="invoice-meta-box">
                    <h5 class="section-label">Invoice Details</h5>
                    <table class="table-invoice-meta">
                        <tr>
                            <td class="meta-label">Invoice No</td>
                            <td class="meta-value"><strong t-field="o.name"/></td>
                        </tr>
                        <tr>
                            <td class="meta-label">Date</td>
                            <td class="meta-value"><span t-field="o.invoice_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                        </tr>
                         <tr>
                            <td class="meta-label">Due Date</td>
                            <td class="meta-value"><span t-field="o.invoice_date_due" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                        </tr>
                        <tr>
                            <td class="meta-label">State</td>
                            <td>
                                <span t-attf-class="status-pill-small #{
                                    'status-posted' if o.state == 'posted' else 
                                    'status-draft' if o.state == 'draft' else 
                                    'status-cancel' if o.state == 'cancel' else 
                                    'status-proforma' if o.state == 'proforma' else 'status-default'}" 
                                    t-field="o.state"/>
                            </td>
                        </tr>
                    </table>
                </div>
            </td>
        </tr>
    </table>

            <div class="table-container">
                <table class="table table-items w-100 table-borderless">
                    <thead>
                        <tr>
                            <th class="text-start" t-attf-style="background-color: {{ header }} !important; color: white !important;">PRODUCT DESCRIPTION</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">HSN/SAC</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">QTY</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">PRICE</th>
                            <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">TAXES</th>
                            <th class="text-end" t-attf-style="background-color: {{ header }} !important; color: white !important;">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr>
                                <td class="text-start">
                                    <strong t-field="line.product_id.name"/><br/>
                                    <span class="text-muted small" t-field="line.name"/>
                                </td>
                                <td class="text-center"><span t-field="line.l10n_in_hsn_code"/></td>
                                <td class="text-center"><span t-field="line.quantity"/></td>
                                <td class="text-center"><span t-field="line.price_unit"/></td>
                                <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                                <td class="text-end"><span t-field="line.price_subtotal"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <div class="row mt-4">
                <div class="col-7 payment-box" >
                    <div class="payment-details-box mb-4">
                        <h6 class="section-header-custom" t-attf-style="color: {{ primary }}; border-bottom: 2px solid {{ primary }};">Payment Info</h6>
                        <div class="detail-row"><strong>Payment Terms: </strong> <span t-field="o.invoice_payment_term_id"/></div>
                        <div class="detail-row"><strong>Payment Reference: </strong> <span t-field="o.payment_reference"/></div>
                        <div class="detail-row"><strong>Amount in Words: </strong> <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/></div>
                    </div>
                </div>
                <div class="col-5">
                    <table class="table-calculation w-100 table-borderless">
                        <tr>
                            <td class="py-2">Sub Total</td>
                            <td class="py-2 text-end"><span t-field="o.amount_untaxed"/></td>
                        </tr>
                        <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                            <tr>
                                                <td t-esc="tax_group['group_name']"/>
                                                <td class="text-end" t-esc="tax_group['tax_amount_currency']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </tr>
                                        </t>
                            </t>
                        <tr class="final-amount-highlight" t-attf-style="background-color: {{ primary }} !important;">
                            <td class="py-3 ps-2" style="color: white !important;">GRAND TOTAL</td>
                            <td class="py-3 pe-2 text-end" style="color: white !important;"><span t-field="o.amount_total"/></td>
                        </tr>
                    </table>
                </div>
            </div>

            <t t-if="o.narration">
                <div class="terms-box" >
                    <div class="terms-detail-box mb-4">
                        <h6 class="section-header-custom" t-attf-style="color: {{ primary }}; border-bottom: 2px solid {{ primary }};">Terms &amp; Condition</h6>
                        <div t-esc="o.narration"></div>
                    </div>
                </div>
            </t>

            <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
            <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" style="width: 100%;">
                                        <table class="table-items table-borderless w-100" style="width: 100%; table-layout: fixed;">
                                            <thead>
                                                <th t-attf-style="background-color: {{ header }} !important; color: white !important;">HSN/SAC</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">Quantity</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">Rate %</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; color: white !important;">Taxable Value</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; color: white !important;">SGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; color: white !important;">CGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="background-color: {{ header }} !important; color: white !important;">IGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="background-color: {{ header }} !important; color: white !important;">CESS</th>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item">
                                                <td t-esc="item['l10n_in_hsn_code']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>
        </div>
    </t>
</template>

    <!-- MAIN WRAPPER -->
    <template id="report_invoice_3">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_3"/>
            </t>
        </t>
    </template>
</odoo>
