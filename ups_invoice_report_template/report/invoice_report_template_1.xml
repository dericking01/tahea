<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="custom_invoice_report_1">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '' "/>
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '' "/>
        <t t-set="header" t-value="res_company.invoice_header_color or '' "/>
        
        <t t-set="r" t-value="int((header or '#EBE7E2')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#EBE7E2')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#EBE7E2')[5:7], 16)"/>
        <t t-set="th_bg" t-value="'rgba(%s, %s, %s, 0.3)' % (r, g, b) if header else '#333333'"/>

        <t t-set="o" t-value="o.with_context(lang=lang)" />
        <div class="page invoice_page_1">
            <table class="layout-table table-borderless">
                <tr>
                   <td class="sidebar-left" t-attf-style="background-color: {{ secondary or '#333333' }} !important;">
                        <div class="logo-container">
                            <div class="logo-box">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" alt="Logo"/>
                            </div>
                        </div>
                        
                        <div class="sidebar-content">
                            <div class="company-info-block">
                                <h4 class="company_name" t-attf-style="color: {{ primary or '#f5deb3' }};">
                                    <span t-field="res_company.name"/>
                                </h4>
                                <p><span t-field="res_company.street"/></p>
                                <p><span t-field="res_company.city"/>, <span t-field="res_company.zip"/></p>
                                <p><span t-field="res_company.email"/></p>
                                <p><span t-field="res_company.phone"/></p>
                            </div>

                            <div class="meta-block">
                                <div class="meta-item">
                                    <strong t-attf-style="color: {{ primary or '#ffffff' }};">INVOICE NO</strong>
                                    <span t-field="o.name"/>
                                </div>
                                <div class="meta-item">
                                    <strong t-attf-style="color: {{ primary or '#ffffff' }};">DATE</strong>
                                    <span t-field="o.invoice_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                                </div>
                            </div>
                        </div>

                        <div class="sidebar-footer">
                            <h2 t-attf-style="color: {{ primary or '#ffffff' }};">THANK YOU</h2>
                            <p>FOR YOUR BUSINESS!</p>
                        </div>
                    </td>
                    <td class="main-right">
                        <div class="header-top text-end">
                            <h1 class="display-1" t-attf-style="color: {{ primary or '#444444' }};">INVOICE</h1>
                        </div>

                        <div class="state_header_container">
                            <div class="header-logo-wrapper">
                                <div class="status-container">
                                    <span t-if="o.state == 'draft'" class="status-badge state-draft">DRAFT</span>
                                    <span t-if="o.state == 'posted'" class="status-badge state-posted">POSTED</span>
                                    <span t-if="o.state == 'cancel'" class="status-badge state-cancel">CANCELLED</span>
                                    <span t-if="o.state not in ['draft', 'posted', 'cancel']" class="status-badge state-default" t-field="o.state"/>
                                </div>
                            </div>
                        </div>

                        <table class="address-table table-borderless">
                            <tr>
                                <td style="width: 50%;">
                                    <strong class="text-uppercase" t-attf-style="color: {{ primary or '#333333' }};">To:</strong><br/>
                                    <span t-field="o.partner_id.name"/><br/>
                                    <div t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                                </td>

                               
                                 <td style="width: 50%;">
                                     <t t-if="o.partner_id.vat">
                                        <p><strong t-attf-style="color: {{ primary or '#333333' }};">GSTIN: </strong><span t-field="o.partner_id.vat"/></p>
                                    </t>
                                    <t t-if="o.l10n_in_state_id.name">
                                        <p><strong t-attf-style="color: {{ primary or '#333333' }};">Place of Supply: </strong><span t-esc="o.l10n_in_state_id.name"/></p>
                                    </t>
                                </td>
                            </tr>
                        </table>

                        <table class="info-bar-table">
                            <thead>
                                <tr>
                                    <th t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">SALESPERSON</th>
                                    <th t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">PAYMENT TERMS</th>
                                    <th t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">DUE DATE</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-field="o.user_id.name"/></td>
                                    <td><span t-field="o.invoice_payment_term_id.name"/></td>
                                    <td><span t-field="o.invoice_date_due" t-options='{"widget": "date", "format": "dd/ MM/ yy"}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="invoice-lines-zebra table-borderless">
                            <thead>
                                <tr>
                                    <th class="text-start" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">ITEM DESCRIPTION</th>
                                    <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">HSN/SAC</th>
                                    <th t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">QTY</th>
                                    <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">UNIT PRICE</th>
                                    <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">Taxes</th>
                                    <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.invoice_line_ids" t-as="line">
                                    <tr t-attf-style="background-color: {{ (line_index % 2 != 0) and ('rgba(%s, %s, %s, 0.1)' % (r, g, b)) or 'transparent' }} !important;">
                                        <td>
                                            <span class="fw-bold" t-field="line.product_id.name"/><br/>
                                            <small class="text-muted" t-field="line.name"/>
                                        </td>
                                        <td class="text-center"><span t-field="line.product_id.l10n_in_hsn_code"/></td>
                                        <td><span t-field="line.quantity"/></td>
                                        <td class="text-center"><span t-field="line.price_unit"/></td>
                                       <td class="text-center">
                                            <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                                <t t-if="i"> + </t>
                                                <span t-esc="tax.name"/>
                                            </t>
                                        </td>
                                        <td class="text-center fw-bold"><span t-field="line.price_subtotal"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row mt-4">
                            <div class="col-6 payment-term-left-box-style">
                                <div>
                                    <strong t-attf-style="color: {{ primary or '#333333' }};">Payment Info:</strong><br/>
                                   <small> Words: </small> <small> <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/><br/></small>
                                   <small> Reference: </small>  <small><span t-field="o.payment_reference"/></small>
                                </div>
                               
                            </div>
                            <div class="col-6">
                                <table class="totals-table-final table-borderless">
                                    <tr>
                                        <td>SUBTOTAL</td>
                                        <td class="text-end"><span t-field="o.amount_untaxed"/></td>
                                    </tr>
                                    <t t-set="tax_totals" t-value="o.tax_totals"/>
                                    <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                        <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                            <tr>
                                                <td t-esc="tax_group['group_name']"/>
                                                <td class="text-end" t-esc="tax_group['tax_amount_currency']" />
                                            </tr>
                                        </t>
                                    </t>
                                    <tr class="grand-total-row" t-attf-style="border-top: 2px solid {{ primary or '#333333' }};">
                                        <td t-attf-style="color: {{ primary or '#333333' }};">TOTAL</td>
                                        <td class="text-end" t-attf-style="color: {{ primary or '#333333' }};"><span t-field="o.amount_total"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>


                        <t t-if="o.narration">
                            <div class="mt-4 terms-block">
                                    <strong t-attf-style="color: {{ primary or '#333333' }};">Terms &amp; Conditions:</strong><br/>
                                    <p class="text-muted"><t t-esc="o.narration"/></p>
                            </div>
                        </t>

                        <h5 class="mt-4" t-attf-style="color: {{ primary or '#333333' }};">HSN/SAC Summary</h5>
                        <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
                        <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" class="mt-3">
                                        <table class="invoice-lines-zebra table-sm table-borderless col-6">
                                            <thead>
                                                <th t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">HSN/SAC</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">Quantity</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">Rate %</th>
                                                <th class="text-center" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">Taxable Value</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">SGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">CGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">IGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="color: {{ header or '#ffffff' }} !important; background-color: {{ th_bg }} !important;">CESS</th>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item" t-attf-style="background-color: {{ (line_index % 2 != 0) and ('rgba(%s, %s, %s, 0.1)' % (r, g, b)) or 'transparent' }} !important;">
                                                <td t-esc="item['l10n_in_hsn_code']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>
                    </td>
                </tr>
            </table>
        </div>
    </t>
</template>

<template id="report_invoice_custom_1">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-set="lang" t-value="o.partner_id.lang"/>
            <t t-call="ups_invoice_report_template.custom_invoice_report_1" t-lang="lang"/>
        </t>
    </t>
</template>
</odoo>
