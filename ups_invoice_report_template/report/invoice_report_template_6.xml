<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="custom_invoice_report_6">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '#FFCC00'"/> 
        <t t-set="header" t-value="res_company.invoice_header_color or '#2D2D2D'"/>  
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '#F8F9FA'"/> 
        <t t-set="o" t-value="doc.with_context(lang=lang)" />
        
        <div class="page invoice_wrapper" >

            <!-- BACKGROUND LAYER -->
    <div class="invoice-bg"></div>

            <div class="top-yellow-bar" t-attf-style="background-color: {{ primary }} !important;">
                <h1 class="invoice-title">INVOICE</h1>
            </div>

            <div class="logo_header_container">
                <div class="header-logo-wrapper">
                    <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" class="company_logo_img"/>
                </div>
            </div>

            <div class="state_header_container">
                <div class="header-logo-wrapper">
                    <div class="status-container">
                        <span t-if="o.state == 'draft'" class="status-badge state-draft">DRAFT</span>
                        <span t-if="o.state == 'posted'" class="status-badge state-posted">POSTED</span>
                        <span t-if="o.state == 'cancel'" class="status-badge state-cancel">CANCELLED</span>
                        <span t-if="o.state not in ['draft', 'posted', 'cancel']" class="status-badge state-default" t-field="o.state"/>
                    </div>
                </div>
            </div>


            <div class="row info-section">
                <div class="col-4">
                    <h5 class="section-label">Bill To</h5>
                    <h4 class="partner-name" t-field="o.partner_id.name" />
                    <div class="address-text">
                        <span t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    </div>

                <div class="gst-place-box" t-attf-style="border-left: 3px solid {{ primary }};">
                    <t t-if="o.partner_id.vat">
                        <div class="tax-line">
                        <span class="tax-label">GSTIN:</span>
                        <span class="tax-value" t-field="o.partner_id.vat"/>
                    </div>
                    </t>
                    <t t-if="o.l10n_in_state_id.name">
                        <div class="tax-line mt-1">
                        <span class="tax-label">Place of Supply:</span>
                        <span class="tax-value" t-field="o.l10n_in_state_id.name"/>
                    </div>
                    </t>
                </div>
                </div>

                <div class="col-4 supply-div">
                    <h5 class="section-label">Supplier</h5>
                    <h4 class="company-name" t-field="o.company_id.name" />
                    <div class="address-text">
                        <span t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    </div>
                </div>

                <div class="col-4 d-flex justify-content-end">
                    <div class="meta-wrapper" t-attf-style="border-top: 2px solid {{ header }};">
                        <div class="meta-item">
                            <span class="meta-label">Invoice No</span>
                            <span class="meta-value" t-field="o.name"/>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Date</span>
                            <span class="meta-value" t-field="o.invoice_date" t-options='{"widget": "date", "format": "dd/MM/yy"}'/>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Due Date</span>
                            <span class="meta-value" t-field="o.invoice_date_due" t-options='{"widget": "date", "format": "dd/MM/yy"}'/>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">State</span>
                            <span class="meta-value" t-field="o.state"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-container mt-4">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th class="col-sl" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">SL.</th>
                            <th class="col-desc" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Item Description</th>
                            <th class="col-qty" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Qty</th>
                            <th class="col-hsn-sac" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">HSN/SAC </th>
                            <th class="col-unit" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Taxes</th>
                            <th class="col-price" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Price</th>
                            <th class="col-total" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="i" t-value="1"/>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr>
                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;"><t t-esc="i"/></td>
                                <td class="cell-desc" t-attf-style="background-color: {{ secondary }} !important;">
                                    <span t-field="line.name"/>
                                </td>
                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;"><span t-field="line.quantity"/></td>
                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;"><span t-field="line.product_id.l10n_in_hsn_code"/></td>
                                <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;"><span t-field="line.price_unit"/></td>
                                <td class="text-center cell-bold" t-attf-style="background-color: {{ secondary }} !important;"><span t-field="line.price_subtotal"/></td>
                            </tr>
                            <t t-set="i" t-value="i+1"/>
                        </t>
                    </tbody>
                </table>
            </div>

            <div class="bottom-section">
               <div class="totals-wrapper">
                        <table class="totals-display table-borderless">
                            <tr>
                                <td class="lbl">Untaxed Amount</td>
                                <td class="val"><span t-field="o.amount_untaxed"/></td>
                            </tr>
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                    <tr class="tax-row">
                                        <td class="lbl" t-esc="tax_group['group_name']"/>
                                        <td class="val" t-esc="tax_group['tax_amount_currency']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </tr>
                                </t>
                            </t>
                            <tr class="grand-total-box" t-attf-style="border-top: 2px solid {{ header }};">
                                <td class="lbl-total">Total</td>
                                <td class="val-total"><span t-field="o.amount_total"/></td>
                            </tr>
                        </table>
                    </div>

                    <div t-if="o.narration" class="narration-section">
                        <div class="pill-label" t-attf-style="background-color: {{ primary }};">Notes &amp; Terms</div>
                        <div class="content-text" t-field="o.narration"/>
                    </div>
                </div>

            <div class="payment-accent-container">
                <div class="payment-wrapper" t-attf-style="border-left: 4px solid {{ primary }};">
                    <div class="payment-meta">
                        <span class="meta-label">Reference</span>
                        <div class="meta-value" t-field="o.payment_reference"/>
                    </div>
                    <div class="payment-meta">
                        <span class="meta-label">Payment Terms</span>
                        <div class="meta-value" t-field="o.invoice_payment_term_id"/>
                    </div>
                    <div class="words-section">
                        <span class="meta-label">Amount in Words</span>
                        <div class="words-value" t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                    </div>
                    <div class="total-section" t-attf-style="background-color: {{ header }} !important;">
                        <span class="meta-label text-white">Total Payable</span>
                        <div class="total-value" t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </div>
                </div>
            </div>

            <div class="table-container mt-4">
                <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
                <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" class="mt-3">
                                        <table class="table-custom table-sm table-borderless col-6">
                                            <thead>
                                                <th t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">HSN/SAC</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Quantity</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Rate %</th>
                                                <th class="text-center" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">Taxable Value</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">SGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">CGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">IGST</th>
                                                <th class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="background-color: {{ header }} !important; border: 1px solid {{ header }};">CESS</th>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item">
                                                <td t-esc="item['l10n_in_hsn_code']" t-attf-style="background-color: {{ secondary }} !important;"/>
                                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']" t-attf-style="background-color: {{ secondary }} !important;"/>
                                                <td class="text-center" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']" t-attf-style="background-color: {{ secondary }} !important;">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>
                </div>
        </div>
    </t>
</template>


<!-- MAIN WRAPPER -->
    <template id="report_invoice_6">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_6"/>
            </t>
        </t>
    </template>

</odoo>
