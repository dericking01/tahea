<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="custom_invoice_report_9">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '#1a3a4d'"/> 
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '#e9ecef'"/>  
        <t t-set="header" t-value="res_company.invoice_header_color or '#1a3a4d'"/> 
        
        <t t-set="r" t-value="int((header or '#1a3a4d')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#1a3a4d')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#1a3a4d')[5:7], 16)"/>
        <t t-set="row_bg" t-value="'rgba(%s, %s, %s, 0.1)' % (r, g, b)"/>

        <t t-set="o" t-value="doc.with_context(lang=lang)" />
        
        <div class="page invoice_page_9">
            <div class="sidebar-accent" t-attf-style="background-color: {{ primary }} !important;"></div>

            <div class="main-content">
                <div class="header-section">
    <table class="w-100 table-borderless header-layout-table">
        <tr>
            <td class="header-logo-side">
                <div class="logo-container">
                    <div class="logo-box">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" alt="Logo"/>
                    </div>
                </div>
            </td>

            <td class="header-text-side text-end">
                <div class="title-status-wrapper">
                    <h1 class="invoice-title" t-attf-style="color: {{ primary }} !important;">INVOICE</h1>
                    <div class="status-pill-container">
                        <span t-attf-class="badge rounded-pill status-pill #{
    'status-posted' if o.state == 'posted' else 
    'status-draft' if o.state == 'draft' else 
    'status-cancel' if o.state == 'cancel' else 
    'status-default'}" 
    t-field="o.state"/>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</div>

                <div class="row address-section">
                    <div class="col-4">
                        <label t-attf-style="color: {{ primary }} !important; font-weight: bold;">INVOICE FROM</label>
                        <div class="address-details">
                            <strong t-field="res_company.name"/><br/>
                            <span t-field="res_company.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        </div>
                    </div>
                    <div class="col-4">
                        <label t-attf-style="color: {{ primary }} !important; font-weight: bold;">INVOICE TO</label>
                        <div class="address-details">
                            <strong t-field="o.partner_id.name"/><br/>
                            <span t-field="o.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                        </div>
                    </div>
                    <div class="col-4 text-end">
                        <div class="meta-info" t-attf-style="border-left: 3px solid {{ primary }}; padding-left: 10px;">
                            <strong>NUMBER : </strong><span t-field="o.name"/><br/>
                            <strong>DATE : </strong><span t-field="o.invoice_date"/><br/>
                            <strong>DUE DATE : </strong><span t-field="o.invoice_date_due"/><br/>
                            <t t-if="o.partner_id.vat">
                                <strong>GSTIN : </strong><span t-field="o.partner_id.vat"/><br/>
                            </t>
                            <t t-if="condition">
                                <strong>Place of Supply : </strong><span t-field="o.l10n_in_state_id.name"/>
                            </t>
                        </div>
                    </div>
                </div>

                <table class="table table-custom mt-4">
                    <thead>
                        <tr t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">
                            <th width="45%" style="padding: 12px;">DESCRIPTION</th>
                            <th class="text-center">HSN/SAC</th>
                            <th class="text-center">QTY</th>
                            <th class="text-center">PRICE</th>
                            <th class="text-center">TAXES</th>
                            <th class="text-end" style="padding-right: 12px;">TOTAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                                <td style="padding: 10px;"><span t-field="line.name"/></td>
                                <td class="text-center"><span t-field="line.product_id.l10n_in_hsn_code"/></td>
                                <td class="text-center"><span t-field="line.quantity"/></td>
                                <td class="text-center"><span t-field="line.price_unit"/></td>
                                <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                                <td class="text-end" style="padding-right: 10px;"><span t-field="line.price_subtotal"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <div class="row footer-section mt-2">
                    <div class="col-7 payment-column">
                        <label t-attf-style="color: {{ primary }} !important; font-weight: bold;">PAYMENT METHOD</label>
                        <div class="payment-box" t-attf-style="background-color: {{ secondary }} !important; padding: 15px; border-radius: 5px;">
                            <strong>Payment Terms </strong> <i class="fa fa-caret-right" t-attf-style="color: {{ primary }};"></i> <span t-field="o.invoice_payment_term_id.name"/><br/>
                            <strong>Payment Reference</strong> <i class="fa fa-caret-right" t-attf-style="color: {{ primary }};"></i> <span t-field="o.payment_reference"/><br/>
                            <strong>Total in Words</strong> <i class="fa fa-caret-right" t-attf-style="color: {{ primary }};"></i> <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/><br/>
                        </div>

                        <t t-if="o.narration">
                            <div class="terms-section mt-4">
                                <label t-attf-style="color: {{ primary }} !important; font-weight: bold;">TERMS &amp; CONDITIONS</label>
                                <p class="terms-text text-muted" t-field="o.narration"/>
                                <t t-if="not o.narration">
                                    <p class="terms-text text-muted" t-esc="o.narration"></p>
                                </t>
                            </div>
                        </t>
                    </div>
                    <div class="col-5">
                        <table class="table table-borderless totals-table">
                            <tr>
                                <td class="text-start text-muted">SUBTOTAL</td>
                                <td class="text-end val"><span t-field="o.amount_untaxed"/></td>
                            </tr>
                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                            <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                    <tr>
                                        <td t-esc="tax_group['group_name']"/>
                                        <td class="text-end" t-esc="tax_group['tax_amount_currency']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </tr>
                                </t>
                            </t>
                            <tr class="grand-total-row" t-attf-style="background-color: {{ primary }} !important; color: #FFFFFF !important;">
                                <td class="text-start fw-bold" style="padding: 10px;">TOTAL</td>
                                <td class="text-end val fw-bold" style="padding: 10px;"><span t-field="o.amount_total"/></td>
                            </tr>
                        </table>
                    </div>
                </div>


                <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
                <t t-if="hsn_summary">
                <div name="l10n_in_hsn_summary" style="width: 100%;">
                    <h5 class="mt-3" t-attf-style="color: {{ primary }} !important; font-weight: bold;"> HSN/SAC Summary </h5>
                    <table class="table-custom table-sm table-borderless w-100" style="width: 100%;">
                        <thead>
                            <tr t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">
                                <th>HSN/SAC</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-center">Rate %</th>
                                <th class="text-center">Taxable Value</th>
                                <th class="text-center" t-if="hsn_summary['has_gst']">SGST</th>
                                <th class="text-center" t-if="hsn_summary['has_gst']">CGST</th>
                                <th class="text-center" t-if="hsn_summary['has_igst']">IGST</th>
                                <th class="text-center" t-if="hsn_summary['has_cess']">CESS</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr t-foreach="hsn_summary['items']" t-as="item" t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                                <td t-esc="item['l10n_in_hsn_code']"/>
                                <td class="text-center">
                                    <span t-esc="item['quantity']"/>
                                    <span t-if="hsn_summary['display_uom']">
                                        (<t t-esc="item['uom_name']"/>)
                                    </span>
                                </td>
                                <td class="text-center" t-esc="item['rate']"/>
                                <td class="text-center">
                                    <span t-esc="item['amount_untaxed']"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                    <span t-esc="item['tax_amount_sgst']"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                    <span t-esc="item['tax_amount_cgst']"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                    <span t-esc="item['tax_amount_igst']"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                    <span t-esc="item['tax_amount_cess']"
                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
        </t>

            </div>
        </div>            
    </t>
</template>

    <template id="report_invoice_9">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_9"/>
            </t>
        </t>
    </template>
</odoo>