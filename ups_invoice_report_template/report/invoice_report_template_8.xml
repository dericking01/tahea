<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="custom_invoice_report_8">
    <t t-call="ups_invoice_report_template.external_layout_invoice_custom">
        <t t-set="primary" t-value="res_company.invoice_primary_color or '#002E5D'"/> 
        <t t-set="secondary" t-value="res_company.invoice_secondary_color or '#F4F7F9'"/>  
        <t t-set="header" t-value="res_company.invoice_header_color or '#2D2D2D'"/> 
        
        <t t-set="r" t-value="int((header or '#2D2D2D')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#2D2D2D')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#2D2D2D')[5:7], 16)"/>
        <t t-set="row_bg" t-value="'rgba(%s, %s, %s, 0.1)' % (r, g, b)"/>

        <t t-set="o" t-value="doc.with_context(lang=lang)" />
        <div class="page invoice_page_8">
            
           <div class="invoice_header" t-attf-style="background-color: {{ secondary }} !important; border-bottom: 5px solid {{ primary }};">
                <table class="header_wrapper_table table-borderless">
                    <tr>
                        <td class="brand_side">
                            <div class="logo_badge">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)"/>
                            </div>
                            <div class="title_group" t-attf-style="border-left: 6px solid {{ primary }};">
                                <h1 class="main_title" t-attf-style="color: {{ primary }} !important;">INVOICE</h1>
                                <div class="status-pill-wrapper">
                                    <span t-attf-class="badge rounded-pill status-pill-style #{'status-posted' if o.state == 'posted' else 'status-draft'}" 
                                        t-field="o.state"/>
                                </div>
                            </div>
                        </td>

                        <td class="info_side">
                            <h2 class="co_name" t-attf-style="color: {{ primary }} !important;" t-field="res_company.name"/>
                            <div class="co_details">
                                <div class="details" t-field="o.company_id.partner_id" t-options='{"widget": "contact", "fields": ["name", "address"], "no_marker": True}'/>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>

            <div class="info_grid">
                <table class="w-100 layout-table table-borderless">
                    <tr>
                        <td class="info-node bill-to-node">
                            <label class="grid-label" t-attf-style="color: {{ primary }};">BILL TO</label>
                            <div class="content-box">
                                <div class="partner-name-bold" t-field="o.partner_id.name"/>
                                <div class="partner-address-muted" t-field="o.partner_id"
                                    t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                            </div>

                             <div class="gst-place-box" t-attf-style="border-left: 3px solid {{ primary }};">
                                <t t-if="o.partner_id.vat">
                                    <div class="tax-line">
                                    <span class="tax-label">GSTIN:</span>
                                    <span class="tax-value" t-field="o.partner_id.vat"/>
                                </div>
                                </t>
                                <t t-if="o.l10n_in_state_id.name">
                                    <div class="tax-line mt-1">
                                    <span class="tax-label">Place of Supply:</span>
                                    <span class="tax-value" t-field="o.l10n_in_state_id.name"/>
                                </div>
                                </t>
                            </div>
                        </td>

                        <td class="info-node date-node" t-attf-style="border-left: 2px solid {{ primary }};">
                            <div class="date-wrapper">
                                <div class="date-item mb-3">
                                    <label class="grid-label" t-attf-style="color: {{ primary }};">ISSUED</label>
                                    <div class="val-text fw-bold" t-field="o.invoice_date" t-options='{"widget": "date", "format": "MMMM d, yyyy"}'/>
                                </div>
                                <div class="date-item">
                                    <label class="grid-label" t-attf-style="color: {{ primary }};">DUE DATE</label>
                                    <div class="val-text fw-bold" t-field="o.invoice_date_due" t-options='{"widget": "date", "format": "MMMM d, yyyy"}'/>
                                </div>
                            </div>
                        </td>

                        <td class="info-node number-node text-end">
                            <div class="ref-box" t-attf-style="background-color: {{ primary }};">
                                <label class="grid-label">NUMBER</label>
                                <div class="invoice-number-text" t-field="o.name"/>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>

            <table class="clm_table table-borderless">
                <thead>
                    <tr t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">
                        <th class="text-start" style="padding: 10px;">DESCRIPTION</th>
                        <th class="text-center">HSN/SAC</th>
                        <th class="text-center">QTY</th>
                        <th class="text-center">PRICE</th>
                        <th class="text-center">Taxes</th>
                        <th class="text-end" style="padding-right: 10px;">TOTAL</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="o.invoice_line_ids" t-as="line">
                        <tr t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                            <td class="text-start" style="padding: 10px;"><span t-field="line.name"/></td>
                            <td class="text-center"><span t-field="line.product_id.l10n_in_hsn_code"/></td>
                            <td class="text-center"><span t-field="line.quantity"/></td>
                            <td class="text-center"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                            <td class="text-center">
                                    <t t-foreach="line.tax_ids" t-as="tax" t-enumerate="i">
                                        <t t-if="i"> + </t>
                                        <span t-esc="tax.name"/>
                                    </t>
                                </td>
                            <td class="text-end" style="padding-right: 10px;"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="row mt-3" style="page-break-inside: avoid;">
                <!-- PAYMENT INFO -->
                <div class="col-6">
                    <div class="bank_box">
                        <h6 class="section-title">Payment Information</h6>
                        <div class="bank_content">
                            <p>
                                <strong>Amount in Words:</strong><br/>
                                <span t-esc="o.currency_id.amount_to_text(o.amount_total)"/>
                            </p>
                            <p>
                                <strong>Payment Terms:</strong><br/>
                                <span t-field="o.invoice_payment_term_id.name"/>
                            </p>
                            <p t-if="o.payment_reference">
                                <strong>Reference:</strong><br/>
                                <span t-field="o.payment_reference"/>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- TOTALS -->
                <div class="col-6">
                    <table class="table_totals table-borderless">
                        <tr>
                            <td class="lbl">Subtotal</td>
                            <td class="val"><span t-field="o.amount_untaxed"/></td>
                        </tr>

                        <t t-set="tax_totals" t-value="o.tax_totals"/>
                        <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                            <t t-foreach="subtotal['tax_groups']" t-as="tax_group">
                                <tr>
                                    <td class="lbl" t-esc="tax_group['group_name']"/>
                                    <td class="val"
                                        t-esc="tax_group['tax_amount_currency']"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </tr>
                            </t>
                        </t>

                        <tr class="total_row">
                            <td class="lbl">Grand Total</td>
                            <td class="val"><span t-field="o.amount_total"/></td>
                        </tr>
                    </table>
                </div>
            </div>


            <t t-if="o.narration">
                <div class="footer_text mt-4">
                    <div t-attf-style="color: {{ primary }}; font-weight: bold; border-bottom: 1px solid {{ primary }}; display: inline-block;">Terms &amp; Condition</div>
                    <p class="small text-muted mt-2" t-field="o.narration"/>
                </div>
            </t>

            <h5 t-attf-style="color: {{ primary }}; font-weight: bold;">HSN/SAC Summary</h5>
            <t t-set="hsn_summary" t-value="o._l10n_in_get_hsn_summary_table()"/>
            <t t-if="hsn_summary">
                                    <div name="l10n_in_hsn_summary" class="mt-3">
                                        <table class="clm_table table-sm table-borderless col-6">
                                            <thead>
                                                <tr t-attf-style="background-color: {{ header }} !important; color: #FFFFFF !important;">
                                                    <th>HSN/SAC</th>
                                                    <th class="text-center">Quantity</th>
                                                    <th class="text-center">Rate %</th>
                                                    <th class="text-center">Taxable Value</th>
                                                    <th class="text-center" t-if="hsn_summary['has_gst']">SGST</th>
                                                    <th class="text-center" t-if="hsn_summary['has_gst']">CGST</th>
                                                    <th class="text-center" t-if="hsn_summary['has_igst']">IGST</th>
                                                    <th class="text-center" t-if="hsn_summary['has_cess']">CESS</th>
                                                </tr>
                                            </thead>
                                            <tr t-foreach="hsn_summary['items']" t-as="item" t-attf-style="background-color: {{ row_bg }} !important; border-bottom: 2px solid #FFFFFF;">
                                                <td t-esc="item['l10n_in_hsn_code']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['quantity']"/>
                                                    <span t-if="hsn_summary['display_uom']">(<t t-esc="item['uom_name']"/>)</span>
                                                </td>
                                                <td class="text-center" t-esc="item['rate']"/>
                                                <td class="text-center">
                                                    <span t-esc="item['amount_untaxed']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_sgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_gst']">
                                                    <span t-esc="item['tax_amount_cgst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_igst']">
                                                    <span t-esc="item['tax_amount_igst']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                                <td class="text-center" t-if="hsn_summary['has_cess']">
                                                    <span t-esc="item['tax_amount_cess']"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </t>
        </div>
    </t>
</template>

    <template id="report_invoice_8">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_invoice_report_template.custom_invoice_report_8"/>
            </t>
        </t>
    </template>
</odoo>