<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="account.report_invoice">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="lang" t-value="o.partner_id.lang"/>
                    <t t-set="doc" t-value="o"/>
                    <t t-if="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template1'">
                        <t t-call="ups_invoice_report_template.report_invoice_document_custom" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template2'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_2" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template3'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_3" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template4'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_4" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template5'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_5" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template6'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_6" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template7'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_7" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template8'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_8" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template9'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_9" t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-elif="o.company_id.ups_custom_report and o.company_id.invoice_templates == 'template10'">
                        <t t-call="ups_invoice_report_template.custom_invoice_report_10" t-lang="o.partner_id.lang"/>
                    </t>

                    <t t-elif="o._get_name_invoice_report() == 'account.report_invoice_document'"
                       t-call="account.report_invoice_document"
                       t-lang="lang"/>
                </t>
            </t>
        </template>

</odoo>
