<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="external_layout_invoice_custom">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-if="not company" t-set="company" t-value="res_company"/>


        <t t-set="layout_background_url"
           t-value="'data:image/png;base64,%s' % company.invoice_watermark.decode('utf-8') if company.invoice_watermark else ''"/>

        <div class="header">
            <div t-if="layout_background_url" 
                 t-attf-style="position: fixed; 
                               top: 450px; 
                               left: 0; 
                               width: 100%; 
                               height: 500px; 
                               background-image: url('{{ layout_background_url }}'); 
                               background-repeat: no-repeat; 
                               background-position: center; 
                               background-size: contain;">
            </div>
        </div>


        <div class="article o_report_layout_background"
             t-att-data-oe-model="o and o._name"
             t-att-data-oe-id="o and o.id">
            <t t-out="0"/>
        </div>

        <div class="footer invoice-modern-footer">
        <div class="main-bar">
            <table class="footer-table">
                <tr>
                    <td class="info-cell" t-if="company.phone">
                        <i class="fa fa-phone icon-style"/>
                        <span class="text-data" t-field="company.phone"/>
                    </td>

                    <td class="info-cell" t-if="company.email">
                        <i class="fa fa-envelope icon-style"/>
                        <span class="text-data" t-field="company.email"/>
                    </td>

                    <td class="info-cell" t-if="company.website">
                        <i class="fa fa-globe icon-style"/>
                        <span class="text-data" t-field="company.website"/>
                    </td>

                    <td class="page-section">
                        <span class="page"/> / <span class="topage"/>
                    </td>
                </tr>
            </table>
        </div>
        
        <div class="footer-company-name">
            <t t-esc="company.name"/>
        </div>
    </div>
    </template>
</odoo>