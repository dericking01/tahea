<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inherit_custom_report_invoice_block" model="ir.ui.view">
        <field name="name">inherit.custom.report.sale.block</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="ups_base_report_template.inherit_config_setting_view"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='custom_report_settings']" position="replace">
                <app name="custom_report_settings" logo="/ups_invoice_report_template/static/description/report_img_setting.png">
                    <!-- keep the original inner content (you may need to copy‑paste it) -->
                </app>
            </xpath>


            <xpath expr="//app[@name='custom_report_settings']" position="inside">
                <block title="Invoice Report Settings" invisible="not ups_custom_report">

                    <!-- Sale Template Selection -->
                    <setting string="Invoice Template" help="Select template for invoice report">
                        <field name="invoice_templates"/>
                    </setting>

                    <!-- Selection of Colors for Template -->
                    <setting string="Select Colors for Template">
                        <group>
                            <row>
                                <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                                    <span>Primary Color:</span>
                                    <field name="invoice_primary_color" widget="color" string="Primary Color"/>
                                </div>
                            </row>

                            <group>
                                <row>
                                   <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                                    <span>Secondary Color:</span>
                                    <field name="invoice_secondary_color" widget="color" string="Secondary Color"/>
                                </div>
                                </row>
                            </group>

                             <group>
                                <row>
                                   <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                                    <span>Header Color:</span>
                                    <field name="invoice_header_color" widget="color" string="Header Color"/>
                                </div>
                                </row>
                            </group>


                            <group>
                                <row>
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <span>Watermark Image:</span>
                                        <field name="invoice_watermark" widget="watermark"/>
                                    </div>
                                </row>
                            </group>
                        </group>

                        <group>
                            <row>
                                <button name="invoice_reset_template_colors" 
                                type="object" 
                                class="btn btn-secondary btn-sm position-relative ms-2 o_custom_colors" 
                                title="Reset to default colors" invisible="not (invoice_primary_color or invoice_secondary_color or invoice_header_color)"> 
                                <i class="fa fa-repeat"/> Reset
                                </button>
                            </row>
                        </group>
                    </setting>

                </block>
            </xpath>

        </field>
    </record>
</odoo>
