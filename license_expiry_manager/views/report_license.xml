<odoo>
    <record id="view_license_report_wizard_form" model="ir.ui.view">
        <field name="name">license.report.wizard.form</field>
        <field name="model">license.report.wizard</field>
        <field name="arch" type="xml">
            <form string="License Report Wizard">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="state"/>
                </group>
                <footer>
                    <button string="Generate Excel" type="object" name="action_generate_excel" class="btn-primary"/>
                    <field name="file_data" filename="file_name"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="action_license_report_wizard" model="ir.actions.act_window">
        <field name="name">License Report Wizard</field>
        <field name="res_model">license.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_license_report_wizard"
            name="License Reports"
            parent="menu_license_root"
            action="action_license_report_wizard"/>


</odoo>
