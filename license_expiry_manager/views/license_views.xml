<odoo>

    <!-- ===================== -->
    <!-- TREE VIEW -->
    <!-- ===================== -->
  <record id="view_license_subscription_tree" model="ir.ui.view">
    <field name="name">license.subscription.tree</field>
    <field name="model">license.subscription</field>
    <field name="arch" type="xml">
        <list decoration-danger="state=='expired'" 
              decoration-warning="state=='expiring'">
            <field name="name"/>
            <field name="type"/>
            <field name="vendor_id"/>
            <field name="expiry_date"/>
            <field name="reminder_days"/>
            <field name="responsible_id"/>
            <field name="cost"/>
            <field name="state"/>
        </list>
    </field>
</record>


    <!-- ===================== -->
    <!-- FORM VIEW -->
    <!-- ===================== -->
    <record id="view_license_subscription_form" model="ir.ui.view">
        <field name="name">license.subscription.form</field>
        <field name="model">license.subscription</field>
        <field name="arch" type="xml">
            <form>
                <button name="action_renew"
                                string="Renew Subscription"
                                type="object"
                                class="btn-success"
                                />
                <sheet>
                        

                    <header>
                        
                        <field name="state" widget="statusbar" statusbar_visible="active,expiring,expired"/>
                        
                    </header>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="type"/>
                            <field name="vendor_id"/>
                            <field name="responsible_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="expiry_date"/>
                            <field name="reminder_days"/>
                        </group>
                    </group>

                    <group>
                        <field name="period_months"/>
                        <field name="cost"/>
                    </group>

                    <notebook>
                        <page string="Subscription Lines">
                            <field name="subscription_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="cost"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>

                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>

                         
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    
    <record id="view_license_status_graph" model="ir.ui.view">
        <field name="name">license.subscription.status.graph</field>
        <field name="model">license.subscription</field>
        <field name="arch" type="xml">
            <graph string="Subscription Status" type="pie">
                <field name="state"/>
                <field name="id" type="measure"/>
            </graph>
        </field>
    </record>


    <!-- ===================== -->
    <!-- ACTION -->
    <!-- ===================== -->
    <record id="action_license_subscription" model="ir.actions.act_window">
        <field name="name">Licenses_Subscriptions</field>
        <field name="res_model">license.subscription</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_license_subscription_search"/> -->
    </record>

    <!-- ===================== -->
    <!-- ACTIONS FOR FILTERED MENUS -->
    <!-- ===================== -->

    <record id="action_license_subscription_expiring" model="ir.actions.act_window">
        <field name="name">Expiring Soon</field>
        <field name="res_model">license.subscription</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','expiring')]</field>
    </record>

    <record id="action_license_subscription_expired" model="ir.actions.act_window">
        <field name="name">Expired</field>
        <field name="res_model">license.subscription</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','expired')]</field>
    </record>

    <!-- ===================== -->
    <!-- MENUS -->
    <!-- ===================== -->

    <menuitem id="menu_license_root" name="Administration Tracker" sequence="10"/>

    <menuitem id="menu_license_all"
              name="Licenses Subscriptions"
              parent="menu_license_root"
              sequence="1"/>

    <menuitem id="menu_license_all_subscription"
              name="Licenses Subscriptions"
              parent="menu_license_all"
              action="action_license_subscription"
              sequence="1"/>

    <menuitem id="menu_license_expiring"
              name="Expiring Soon"
              parent="menu_license_all"
              action="action_license_subscription_expiring"
              sequence="2"/>

    <menuitem id="menu_license_expired"
              name="Expired"
              parent="menu_license_all"
              action="action_license_subscription_expired"
              sequence="3"/>

</odoo>
