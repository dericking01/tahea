<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hide_payslip_hours_column" model="ir.ui.view">
        <field name="name">hide.payslip.hours.column</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='worked_days_line_ids']/list/field[@name='number_of_hours']"
                   position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>

        </field>
    </record>

</odoo>
