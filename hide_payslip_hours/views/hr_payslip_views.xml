<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payslip_view_form_hide_hours" model="ir.ui.view">
        <field name="name">hr.payslip.form.hide.number.of.hours</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_hours']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
