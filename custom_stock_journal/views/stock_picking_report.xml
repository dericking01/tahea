            <div class="footer">
                <div class="oe_structure"/>
                <div class="row" style="border: 1px solid black; border-radius:15px; width:100%; padding: 5px;">
                    <div class="col-6">
                        <table class="table table-borderless">
                            <tr>
                                <td>
                                    <span t-attf-style="color: #000000;">customer Name:................................................................</span><br/><br/>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-6">
                        <table class="table table-borderless">
                            <tr>
                                <td>
                                    <span t-attf-style="color: #000000;">Signature:............................................................................</span><br/><br/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    </data>
</odoo>