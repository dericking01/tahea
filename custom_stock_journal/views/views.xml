<odoo>

    <record id="view_picking_form_inherit_manual_journal" model="ir.ui.view">
        <field name="name">stock.picking.form.manual.journal.18</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_create_manual_stock_journal"
                        type="object"
                        string="Create Stock COGS Entry"
                        class="oe_highlight"
                        invisible="state != 'done' or picking_type_code != 'outgoing'"
                        groups="stock.group_stock_manager"/>
            </xpath>

            <!-- Add Analytic Account -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="analytic_distribution"
                       widget="analytic_distribution"
                       invisible="picking_type_code != 'incoming'"/>
            </xpath>

            <!--Show created Journal Entry-->
            <xpath expr="//sheet/notebook/page[@name='operations']" position="inside">
                <group>
                    <field name="manual_stock_journal_id" readonly="1"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>