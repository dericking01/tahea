<odoo>
    
     <!-- Action -->
    <record id="action_fuel_logs" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">fleet.fuel.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click 'Create' to add a new fuel log.
            </p>
        </field>
    </record>

    <!-- Independent Menu -->
    <menuitem id="menu_fleet_fuel_root" name="Fuel Management" sequence="10"/>
    <menuitem id="menu_fuel_logs" name="Fuel Logs" parent="menu_fleet_fuel_root" action="action_fuel_logs" sequence="1"/>

    <record id="seq_fleet_fuel_log" model="ir.sequence">
            <field name="name">Fuel Log</field>
            <field name="code">fleet.fuel.log</field>
            <field name="prefix">FUEL/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    <record id="view_fuel_log_tree" model="ir.ui.view">
        <field name="name">fuel.log.tree</field>
        <field name="model">fleet.fuel.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="date"/>
                <field name="total_cost"/>
                <field name="supplier_id"/>
                <field name="analytic_account_id"/>
                <field name="vendor_bill_payment_status"/>
            </list>
        </field>
    </record>

    <record id="view_fuel_log_form" model="ir.ui.view">
    <field name="name">fuel.log.form</field>
    <field name="model">fleet.fuel.log</field>
    <field name="arch" type="xml">
        <form string="Fuel Log">
            
            <!-- Header: show name as form title -->
            <header>
          
                
                <!-- Create Vendor Bill button -->
                <button name="action_create_vendor_bill"
                        string="Create Vendor Bill"
                        type="object"
                        class="btn-primary"
                        />
                
            </header>

            <sheet>
                <!-- Top Information -->
                <group>
                    <group>
                        <!-- Dynamic title -->
                        <field name="name" string="Reference" readonly="1"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="driver_id"/>
                    </group>
                </group>

                <!-- Fuel Details -->
                <group string="Fuel Details" class="o_group_box">
                    <group>
                        <field name="fuel_quantity"/>
                        <field name="unit_price"/>
                        <field name="total_cost" readonly="1"/>
                        <field name="supplier_id"/>
                    </group>
                </group>

                <!-- Accounting / Analytic -->
                <group string="Accounting Info" class="o_group_box">
                    <field name="analytic_account_id"/>
                </group>

                <!-- Notes / Comments -->
                <notebook>
                    <page string="Notes">
                        <field name="notes" placeholder="Enter any notes here..." widget="text" options="{'max_height': 200}"/>
                        
                    </page>
                    <page string="Vendor Bills">
                      <field name="vendor_bill_id"/>
                    </page>
                </notebook>

            </sheet>
        </form>
    </field>
</record> 
</odoo>