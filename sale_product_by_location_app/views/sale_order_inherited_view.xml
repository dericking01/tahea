<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="sale_order_form_inherit_multi_location" model="ir.ui.view">
		<field name="name">sale.order.form.inherit</field>
		<field name="model">sale.order</field>
		<field name="inherit_id" ref="sale.view_order_form"/>
		<field name="arch" type="xml">
			<field name="partner_shipping_id" position="after">
				<field name="is_multi_location" attrs="{'readonly': [('state', 'in', ['sale', 'done'])]}"/>
			</field>
			<xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="before">
				<field name="location_id" domain="[('usage', '=', 'internal')]" attrs="{'column_invisible': [('parent.is_multi_location', '=', False)],'required': [('parent.is_multi_location', '=', True)]}"/>
            </xpath>

			<div name="button_box" position="inside">
				<button type="object" class="oe_stat_button" icon="fa-truck" name="action_view_multi_delivery"
					attrs="{'invisible': [('delivery_count', '=', 0)]}">
					<field string="Delivery" name="delivery_count" widget="statinfo"/>
				</button>
			</div>

		</field>
	</record>

	<record id="view_order_form_inherit_sale_stock" model="ir.ui.view">
		<field name="name">sale.order.form.sale.stock</field>
		<field name="model">sale.order</field>
		<field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
		<field name="arch" type="xml">
			<xpath expr="//button[@name='action_view_delivery']" position="attributes">
				<attribute name="invisible">True</attribute>
			</xpath>
		</field>
	</record>
</odoo>
