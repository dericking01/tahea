 <odoo>
 
 
        <record id="view_approval_request_form_inherit" model="ir.ui.view">
            <field name="name">approval.request.form.inherit.vendor.bills</field>
            <field name="model">approval.request</field>
            <field name="inherit_id" ref="approvals.approval_request_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet/notebook/page[@name='approvers']" position="before">
                    <page string="Vendor Bills">

                        <!-- Lines -->
                        <field name="bill_line_ids" nolabel="1"
                            readonly="request_status in ['pending','approved','refused','cancel']">

                            <list editable="bottom">
                                <field name="partner_id"/>
                                <field name="vendor_bill_ids" widget="many2many_tags"/>
                                <field name="total_bill_amount" sum="Total"/>
                                <field name="planned_amount" sum="Planned"/>
                            </list>

                        </field>

                        <!-- Grand Total -->
                        <group>
                            <field name="total_bill_amount" readonly="1"/>
                            <field name="total_planned_amount" readonly="1"/>
                        </group>

                    </page>
                </xpath>

            </field>
        </record>

</odoo>