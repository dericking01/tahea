<odoo>
<report
    id="action_print_cashier_periodic_report"
    model="cashier.report.wizard"
    string="Periodic Cashier Report"
    report_type="qweb-pdf"
    file="cashier_report.report_cashier_periodic"
    name="cashier_report.report_cashier_periodic"
/>

<template id="report_cashier_periodic">
        <t t-call="web.html_container">
            <div class="page">
                <h3>Cashier Report Summary</h3>

                <!-- Handle case with no data -->
                <t t-if="data['report_data']">
                    <t t-foreach="data['report_data'].items()" t-as="shop">
                        <h4><t t-esc="shop[0]"/></h4>

                        <t t-foreach="shop[1].items()" t-as="sale_type">
                            <strong>Sale Type: <t t-esc="sale_type[0]"/></strong>
                            <table class="table table-sm table-bordered mt16">
                                <thead>
                                    <tr>
                                        <th>Payment Method</th>
                                        <th>Total Sales</th>
                                        <th>Total Expenditure</th>
                                        <th>Balance</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="sale_type[1].items()" t-as="pay_method">
                                        <tr>
                                            <td><t t-esc="pay_method[0]"/></td>
                                            <td><t t-esc="pay_method[1]['total_sales']"/></td>
                                            <td><t t-esc="pay_method[1]['total_expenditure']"/></td>
                                            <td><t t-esc="pay_method[1]['balance']"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </t>
                </t>
                <t t-else="">
                    <p>No report data available for the selected filters.</p>
                </t>
            </div>
        </t>
    </template>

</odoo>
