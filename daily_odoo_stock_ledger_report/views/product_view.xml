<odoo>

    <record id="product_tree_stock_ledger_btn" model="ir.ui.view">
        <field name="name">product.tree.stock.ledger</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <button name="action_open_stock_ledger"
                        type="object"
                        string="View Ledger"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <record id="action_stock_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Stock Ledger</field>
        <field name="res_model">stock.ledger.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu under Inventory Reporting -->
    <menuitem id="menu_stock_ledger"
              name="Stock Ledger"
              parent="stock.menu_warehouse_report"
              action="action_stock_ledger_wizard"/>
</odoo>