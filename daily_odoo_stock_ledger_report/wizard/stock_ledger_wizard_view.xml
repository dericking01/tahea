<odoo>
    <record id="view_stock_ledger_wizard" model="ir.ui.view">
        <field name="name">stock.ledger.wizard.form</field>
        <field name="model">stock.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Stock Ledger">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_generate"
                            string="Generate"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>