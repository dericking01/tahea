<odoo>

    <record id="view_equipment_form" model="ir.ui.view">
        <field name="name">equipment.management.form</field>
        <field name="model">equipment.management</field>
        <field name="arch" type="xml">
            <form string="Equipment">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="serial_number"/>
                        <field name="model_id"/>
                        <field name="manufacturer_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_equipment_tree" model="ir.ui.view">
        <field name="name">equipment.management.tree</field>
        <field name="model">equipment.management</field>
        <field name="arch" type="xml">
            <list string="Equipment">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="model_id"/>
                <field name="manufacturer_id"/>
            </list>
        </field>
    </record>

      <record id="view_manufacturer_form" model="ir.ui.view">
      <field name="name">equipment.manufacturer.form</field>
      <field name="model">equipment.manufacturer</field>
      <field name="arch" type="xml">
          <form string="Manufacturer">
              <sheet>
                  <group>
                      <field name="name"/>
                  </group>
              </sheet>
          </form>
      </field>
  </record>

  <record id="view_manufacturer_tree" model="ir.ui.view">
      <field name="name">equipment.manufacturer.tree</field>
      <field name="model">equipment.manufacturer</field>
      <field name="arch" type="xml">
          <list string="Manufacturer">
              <field name="name"/>
          </list>
      </field>
  </record>

  <record id="view_model_form" model="ir.ui.view">
    <field name="name">equipment.model.form</field>
    <field name="model">equipment.model</field>
    <field name="arch" type="xml">
        <form string="Model">
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="manufacturer_id"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="view_model_tree" model="ir.ui.view">
    <field name="name">equipment.model.tree</field>
    <field name="model">equipment.model</field>
    <field name="arch" type="xml">
        <list string="Model">
            <field name="name"/>
            <field name="manufacturer_id"/>
        </list>
    </field>
</record>

</odoo>