<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Rename report action label shown in Print menu and report metadata -->
        <record id="stock.action_report_delivery" model="ir.actions.report">
            <field name="name">DELIVERY NOTE</field>
        </record>

        <!-- Show DELIVERY NOTE as the document title on the report body -->
        <template id="report_delivery_document_delivery_note_title" inherit_id="stock.report_delivery_document">
            <xpath expr="//div[hasclass('page')]/h2" position="replace">
                <h2>
                    <span>DELIVERY NOTE</span>
                    <br/>
                    <span t-field="o.name">WH/OUT/0001</span>
                </h2>
            </xpath>
        </template>
    </data>
</odoo>
