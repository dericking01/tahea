<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_so_custom_7">
        <t t-call="ups_sale_report_template.external_layout_custom">
            <t t-set="header" t-value="res_company.report_header_color"/>
            <t t-set="r" t-value="int((header or '#525252')[1:3], 16)"/>
            <t t-set="g" t-value="int((header or '#525252')[3:5], 16)"/>
            <t t-set="b" t-value="int((header or '#525252')[5:7], 16)"/>

            
            <t t-foreach="docs" t-as="doc">
                <div class="page sale_order_7">
                   
                            <div class="sale-order-inner">
                                <div class="sale-order-info" t-attf-style="background-image: url('#{image_data_uri(doc.company_id.report_background) if doc.company_id.report_background else '/ups_sale_report_template/static/src/img/background.jpg'}') !important;
                   background-repeat: no-repeat !important;
                   background-size: 100% 100%  !important;">
                                    <div class="sale-order-header">
                                        <div class="row">
                                            <div class="col-6">
                                                <div class="minimal_brand_row">
                                                    <div class="logo_cell">
                                                        <img t-if="doc.company_id.logo" 
                                                            t-att-src="image_data_uri(doc.company_id.logo)" 
                                                            alt="Logo"/>
                                                    </div>
                                                    
                                                    <div class="brand_text_box">
                                                        <div class="name_row" t-field="doc.company_id.name"/>
                                                        <div class="location_row">
                                                            <span t-field="doc.company_id.city"/> | 
                                                            <span t-if="doc.company_id.state_id" t-field="doc.company_id.state_id.name"/> | 
                                                            <span t-field="doc.company_id.country_id.name"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-6 text-end">
                                                <div class="sale-order-title">
                                                    <h1>Order: #<span t-field="doc.name"/></h1>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="sale-order-top">
                                        <div class="row">
                                            <div class="col-6">
                                                <h4 class="inv-title-1">Vendor</h4>
                                                    <p class="invo-addr-1" t-field="doc.company_id.partner_id"
                                                    t-options='{
                                                        "widget": "contact",
                                                        "fields": ["name", "address"],
                                                        "no_marker": True }'/>
                                            </div>
                                            <div class="col-6 text-end">
                                                <h4 class="inv-title-1" t-attf-style = "text-align: right">Bill To</h4>
                                                <p class="invo-addr-1" t-field="doc.partner_id"
                                                    t-options='{
                                                        "widget": "contact",
                                                        "fields": ["name", "address","email"],
                                                        "no_marker": True }'>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="row mt-4">
                                            <div class="col-3">
                                                <h4 class="inv-title-1">Order Date</h4>
                                                <p t-esc="doc.date_order" t-options='{"widget": "date"}'/>
                                            </div>

                                            <div class="col-3">
                                                <h4 class="inv-title-1">Expiration Date</h4>
                                                <p t-esc="doc.validity_date" t-options='{"widget": "date"}'></p>
                                            </div>

                                            <div class="col-6 text-end">
                                                <h4 class="inv-title-1">Payment Terms</h4>
                                                <p t-field="doc.payment_term_id.name" t-attf-style="text-align: left"/>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="sale-order-center">
    <table class="table-borderless table-striped sale-order-table">
        <thead class="bg-active">
            <tr>
                <th t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Description</th>
                <th class="text-center" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Price</th>
                <th class="text-center" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Quantity</th>
                <th class="text-center" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Tax</th>
                <th class="text-end" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Amount</th>
            </tr>
        </thead>
        <tbody>
            <t t-foreach="doc.order_line" t-as="line">
                <tr>
                    <td>
                        <div class="item-desc-1">
                            <span t-field="line.product_id.name"/><br/>
                            <small t-field="line.name"/>
                        </div>
                    </td>
                    <td class="text-center"><span t-field="line.price_unit"/></td>
                    <td class="text-center"><span t-field="line.product_uom_qty"/></td>
                    <td class="text-center">
                        <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                    </td>
                    <td class="text-end"><span t-field="line.price_subtotal"/></td>
                </tr>
            </t>
        </tbody>
    </table>

    <div class="row mt-0" style="page-break-inside: avoid;">
        <div class="col-7 pt-3 terms-condition-block">
            <div t-if="doc.note" class="terms-condition-box-7">
                <h4 class="inv-title-1" t-attf-style="color:{{ header or '#525252' }}">Terms &amp; Conditions</h4>
                <div class="terms-text" t-field="doc.note"/>
            </div>
        </div>
        <div class="col-5 pt-3">
            <table class="table table-borderless summary-table-7">
                <tr>
                    <td class="text-start">SubTotal</td>
                    <td class="text-end"><span t-field="doc.amount_untaxed"/></td>
                </tr>
                <tr>
                    <td class="text-start">Tax</td>
                    <td class="text-end"><span t-field="doc.amount_tax"/></td>
                </tr>
                <tr class="grand-total-row" t-attf-style="background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.05);">
                    <td class="text-start f-w-600">Grand Total</td>
                    <td class="text-end f-w-600"><span t-field="doc.amount_total"/></td>
                </tr>
            </table>
        </div>
    </div>
</div>

                                </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="report_sale_order_template_7">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_7" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>