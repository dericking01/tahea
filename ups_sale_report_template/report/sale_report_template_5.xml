<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_so_custom_5">
        <t t-call="ups_sale_report_template.external_layout_custom">
            <t t-set="primary" t-value="res_company.report_primary_color"/>
            <t t-set="secondary" t-value="res_company.report_secondary_color"/>
            <t t-set="header" t-value="res_company.report_header_color"/>
            <t t-set="r" t-value="int((header or '#ff8a00')[1:3], 16)"/>
            <t t-set="g" t-value="int((header or '#ff8a00')[3:5], 16)"/>
            <t t-set="b" t-value="int((header or '#ff8a00')[5:7], 16)"/>

            <t t-foreach="docs" t-as="order">
                    <div class="page sale_order_5">
                
                        <div class="sale-order-header">
                            <div class="row align-items-center">
                               <div class="col-6">
                                    <div class="logo-wrapper">
                                        <img t-if="order.company_id.logo" t-att-src="image_data_uri(order.company_id.logo)" alt="Logo"/>
                                        
                                        <div class="company-location mt-2" style="font-size: 14px;">
                                            <i class="fa fa-map-marker me-2"/>
                                            <span t-field="order.company_id.state_id.name"/>, 
                                            <span t-field="order.company_id.country_id.name"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 p-0">
                                    <div class="order-info" t-attf-style="background-color : {{secondary or '#ff8a00'}}">
                                        <h1 class="order-title">
                                            <span t-if="order.state in ['draft', 'sent']" t-attf-style="color : {{primary}}">Quotation</span>
                                            <span t-else="" t-attf-style="color : {{primary or '#fff'}}">Sales Order</span>
                                        </h1>
                                        <p class="order-number"># <span t-field="order.name"/></p>
                                        <p class="order-date">Date: <span t-field="order.date_order" t-options='{"widget": "date"}'/></p>
                                        <p class="order-date">Expiration: <span t-field="order.validity_date" t-options='{"widget": "date"}'/></p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="customer-company-info">
                            <div class="row">
                                <div class="col-6">
                                    <div class="info-block" t-attf-style="border-left :4px solid {{secondary or '#ff8a00'}}">
                                        <h4 class="info-title" t-attf-style="color : {{primary or '#ff8a00' }}">Bill To:</h4>
                                        <div class="info-content">
                                            <p class="name-display"><span t-field="order.partner_id.name"/></p>
                                            <div class="address-display">
                                                <div t-field="order.partner_id" 
                                     t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": True}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="info-block" t-attf-style="border-left :4px solid {{secondary or '#ff8a00'}}">
                                        <h4 class="info-title" t-attf-style="color : {{primary or '#ff8a00' }}">From:</h4>
                                        <div class="info-content">
                                            <p class="name-display"><span t-esc="order.company_id.name"/></p>
                                            <div class="address-display">
                                                <div t-field="order.partner_shipping_id"  t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": True}'/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="table-container">
                            <table class="table_modern_minimal table-borderless" t-attf-style="border-bottom :3px solid {{header or '#ff8a00'}}">
                                <thead>
                                    <tr>
                                        <th class="text-center" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">S No</th>
                                        <th class="text-left" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Item &amp; Description</th>
                                        <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Unit Price</th>
                                        <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Qty</th>
                                        <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Taxes</th>
                                        <th class="col_subtotal text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="order.order_line" t-as="line">
                                        <tr t-att-class="'bg-light' if line_index % 2 != 0 else ''">
                                            <td class="text-center"><span t-esc="line_index + 1"/></td>
                                            <td>
                                                <div><strong><span t-field="line.product_id.name"/></strong></div>
                                                <div t-if="line.name != line.product_id.name">
                                                    <span t-field="line.name"/>
                                                </div>
                                            </td>
                                            <td class="text-center"><span t-field="line.price_unit"/></td>
                                            <td class="text-center"><span t-esc="int(line.product_uom_qty)"/></td>
                                            <td class="text-center">
                                               <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                            </td>
                                            <td class="text-center"><span t-field="line.price_subtotal"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div class="totals_wrapper">
                            <div class="row">
                                <div class="col-7 terms-condition-box">
                                    <div class="terms_box" t-if="order.note">
                                        <div class="totals_title" t-attf-style="background-color : {{secondary or '#ff8a00' }}; color : {{primary or '#fff'}}">Terms &amp; Conditions</div>
                                        <div class="terms_content" t-field="order.note"/>
                                    </div>
                                </div>
                                <div class="col-5">
                                    <table class="table_summary table-borderless">
                                        <tr>
                                            <td class="text-left">Subtotal</td>
                                            <td class="text-end"><span t-field="order.amount_untaxed"/></td>
                                        </tr>
                                        <tr>
                                            <td class="text-left">Tax</td>
                                            <td class="text-end"><span t-field="order.amount_tax"/></td>
                                        </tr>
                                        <tr class="total_row" t-attf-style="border-top : 2px solid {{secondary or '#ff8a00' }}">
                                            <td class="text-left" t-attf-style="color : {{primary or '#ff8a00' }}">TOTAL</td>
                                            <td class="text-end">
                                                <span t-attf-style="color : {{primary or '#ff8a00' }}" t-field="order.amount_total" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
            </t>
        </t>
    </template>

     <template id="report_sale_order_template_5">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_5" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>
