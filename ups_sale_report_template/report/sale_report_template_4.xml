<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_so_custom_4">
        <t t-call="ups_sale_report_template.external_layout_custom">
            <t t-set="primary" t-value="res_company.report_primary_color"/>
            <t t-set="secondary" t-value="res_company.report_secondary_color"/>
            <t t-set="header" t-value="res_company.report_header_color"/>
            <t t-set="r" t-value="int((header or '#1a252f')[1:3], 16)"/>
            <t t-set="g" t-value="int((header or '#1a252f')[3:5], 16)"/>
            <t t-set="b" t-value="int((header or '#1a252f')[5:7], 16)"/>

            <t t-foreach="docs" t-as="order">
                <div class="page sale_order_4">
                    <div class="report_header_modern">
                        <div class="row align-items-center mb-5">
                            <div class="col-6">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" class="header_logo"/>
                            </div>
                            <div class="col-6 text-end">
                                <div class="location_card">
                                    <div class="company_name_bold" t-field="res_company.name"/>
                                    <div class="address_line">
                                        <span t-field="res_company.city"/>, 
                                        <span t-if="res_company.state_id" t-field="res_company.state_id.name"/>
                                    </div>
                                    <div class="address_line" t-field="res_company.country_id.name"/>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-5 header-details">
                            <div class="col-7">
                                <div class="title_group">
                                    <h1 class="doc-type-label">
                                        <span t-if="order.state in ['draft', 'sent']" t-attf-style="color: {{ primary or '#1a252f'}};">Quotation</span>
                                        <span t-else="" t-attf-style="color: {{ primary or '#1a252f'}};">Sales Order</span>
                                    </h1>
                                    <h3 class="doc-number" t-attf-style="border-left: 4px solid {{ primary or '#3498db'}};">
                                        <span t-field="order.name"/>
                                    </h3>
                                </div>
                            </div>
                            <div class="col-5">
                                <div class="meta-data-box" t-attf-style="border-bottom: 3px solid {{ primary or '#3498db'}};">
                                    <div class="meta_row">
                                        <span class="meta_label">Order Date</span>
                                        <span class="meta_value" t-field="order.date_order" t-options='{"widget": "date"}'/>
                                    </div>
                                    <div class="meta_row" t-if="order.validity_date">
                                        <span class="meta_label">Expiration</span>
                                        <span class="meta_value" t-field="order.validity_date" t-options='{"widget": "date"}'/>
                                    </div>
                                    <div class="meta_row" t-if="order.user_id">
                                        <span class="meta_label">Salesperson</span>
                                        <span class="meta_value" t-field="order.user_id.name"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-5">
                        <div class="col-6">
                            <div class="address-title">Billing Address</div>
                            <div class="address-card" t-attf-style="border-left: 3px solid {{ primary or '#3498db' }}; padding-left: 10px;">
                                <strong class="partner-name" t-field="order.company_id.partner_id.name"/>
                                <div t-field="order.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": True}'/>
                            </div>
                        </div>
                        <div class="col-6" t-if="order.partner_shipping_id">
                            <div class="address-title">Shipping Address</div>
                            <div class="address-card" t-attf-style="border-left: 3px solid {{ primary or '#3498db' }}; padding-left: 10px;">
                                <strong class="partner-name" t-field="order.partner_shipping_id.name"/>
                                <div t-field="order.partner_shipping_id" t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": True}'/>
                            </div>
                        </div>
                    </div>

                    <table class="table modern-table mt-4">
                        <thead>
                            <tr>
                                <th class="text-center" t-attf-style="color:{{ header or '#333333' }}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">S No</th>
                                <th t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Description</th>
                                <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Qty</th>
                                <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Unit Price</th>
                                <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Taxes</th>
                                <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="order.order_line" t-as="line">
                                <tr t-att-class="'line-section fw-bold' if line.display_type == 'line_section' else 'line-note fst-italic' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td class="text-center"><span t-esc="line_index + 1"/></td>
                                        <td>
                                            <div class="product-name" t-field="line.product_id.name"/>
                                            <div class="product-description text-muted small" t-field="line.name" t-if="line.name != line.product_id.name"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="int(line.product_uom_qty)"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                        </td>
                                        <td class="text-center">
                                            <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                        </td>
                                        <td class="text-center fw-bold">
                                            <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                        </td>
                                    </t>
                                    <t t-else="">
                                        <td colspan="6">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <div class="row" style="page-break-inside: avoid;">
                        <div class="col-7 term-column">
                            <div class="terms-section" t-if="order.note or order.payment_term_id">
                                <div class="address-title">Terms &amp; Notes</div>
                                <p class="small text-muted" t-field="order.payment_term_id.note"/>
                                <div class="small" t-field="order.note"/>
                            </div>
                        </div>
                        <div class="col-5">
                            <div class="totals-box" t-attf-style="background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">
                                <div class="row py-2 border-bottom">
                                    <div class="col-7" t-attf-style="color: {{header or '#333333'}}">Subtotal</div>
                                    <div class="col-5 text-end fw-bold" t-attf-style="color: {{header or '#333333'}}"><span t-field="order.amount_untaxed"/></div>
                                </div>
                                <div class="row py-2 border-bottom">
                                    <div class="col-7" t-attf-style="color: {{header or '#333333'}}">Taxes</div>
                                    <div class="col-5 text-end fw-bold" t-attf-style="color: {{header or '#333333'}}"><span t-field="order.amount_tax"/></div>
                                </div>
                                <div class="row py-3 total-row">
                                    <div class="col-7 text-uppercase fw-bold" t-attf-style="color: {{header or '#333333'}}">Total</div>
                                    <div class="col-5 text-end total-amount"><span t-field="order.amount_total" t-attf-style="color : {{ primary or '#3498db' }}"/></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="report_sale_order_template_4">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_4" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>