<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_so_custom_8">
    <t t-call="ups_sale_report_template.external_layout_custom">
        <t t-set="primary" t-value="res_company.report_primary_color"/>
        <t t-set="secondary" t-value="res_company.report_secondary_color"/>
        <t t-set="header" t-value="res_company.report_header_color"/>
        <t t-set="r" t-value="int((header or '#f5f7fc')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#f5f7fc')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#f5f7fc')[5:7], 16)"/>

        <t t-foreach="docs" t-as="doc">
            <div class="page sale_order_8" t-attf-style=" background-image: url('#{image_data_uri(doc.company_id.report_background) if doc.company_id.report_background else '/ups_sale_report_template/static/src/img/img-5.jpg'}') !important;
                   background-repeat: no-repeat !important;
                   background-position: left top !important;
                   background-size: contain !important;
                   min-height: 1100px;">

                <div class="sale_order_info" >
                    <table class="structure_table table-borderless">
                        <tr>
                            <td class="col-6 sale_order_info">
                                <div class="brand_stack_container">
                                    <div class="sale_order_logo">
                                        <img t-if="doc.company_id.logo" 
                                            t-att-src="image_data_uri(doc.company_id.logo)" 
                                            alt="logo"/>
                                    </div>
                                    
                                    <div class="brand_details">
                                        <h3 class="brand_name" t-field="doc.company_id.name"/>
                                        <div class="brand_address">
                                            <div class="address_line">
                                                <i class="fa fa-map-marker icon_location"/>
                                                <span t-field="doc.company_id.city"/>, 
                                                <span t-if="doc.company_id.state_id" t-field="doc.company_id.state_id.name"/>
                                            </div>
                                            <div class="brand_country" t-field="doc.company_id.country_id.name"/>
                                        </div>
                                    </div>
                                </div>
                            </td>

                            
                           <td class="col-6 text-end sale_order_contact_column">
                                <div class="sale_order_contact_us">
                                    <h1 class="inv-title-1" t-attf-style="color:{{primary or '#1f78ff'}}">Contact Us</h1>
                                    <div class="contact-details">
                                        <div class="contact-item">
                                            <span t-field="doc.company_id.street"/>
                                            <i class="fa fa-map-marker icon-style" t-attf-style="color:{{primary or '#1f78ff'}}"/>
                                        </div>
                                        <div class="contact-item">
                                            <span t-field="doc.company_id.email"/>
                                            <i class="fa fa-envelope icon-style" t-attf-style="color:{{primary or '#1f78ff'}}"/>
                                        </div>
                                        <div class="contact-item">
                                            <span t-field="doc.company_id.phone"/>
                                            <i class="fa fa-phone icon-style" t-attf-style="color:{{primary or '#1f78ff'}}"/>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <div class="sale_order_main_content">
                        <div class="content-header-padding">
                            <table class="structure_table table-borderless">
                                <tr>
                                    <td><h1 class="sale_order_label" t-attf-style="color:{{secondary or '#1f78ff'}}">Sale Order</h1></td>
                                    <td class="text-end">
                                        <div class="sale_order_number_inner">
                                            <h2 class="name">Order no: <span t-field="doc.name"/></h2>
                                            <p class="order-date">Order Date: <span t-field="doc.date_order" t-options='{"widget": "date"}'/></p>
                                            <p class="order-date">Expiration Date: <span t-field="doc.validity_date" t-options='{"widget": "date"}'/></p>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div class="content-address-padding">
                            <table class="structure_table table-borderless">
                                <tr>
                                    <td class="col-6">
                                        <h4 class="inv-title-1" t-attf-style="color:{{primary or '#1f78ff'}}">Customer</h4>
                                        <h2 class="name" t-field="doc.partner_id.name"/>
                                        <div class="address-text" t-field="doc.partner_id" t-options='{"widget": "contact", "fields": ["address", "email"], "no_marker": True}'/>
                                    </td>
                                    <td class="col-6 text-end">
                                        <h4 class="inv-title-1" t-attf-style="color:{{primary or '#1f78ff'}}">Company Info</h4>
                                        <h2 class="name" t-field="doc.company_id.name"/>
                                        <div class="address-text" t-field="doc.company_id.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div class="sale_order_center">
                            <table class="sale_order_table table-borderless">
                                <thead>
                                    <tr>
                                        <th t-attf-style="color:{{ header or '#1f78ff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Description</th>
                                        <th t-attf-style="color:{{ header or '#1f78ff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12);" class="text-end">Qty</th>
                                        <th t-attf-style="color:{{ header or '#1f78ff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12);" class="text-end">Price</th>
                                        <th t-attf-style="color:{{ header or '#1f78ff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12);" class="text-center">Tax</th>
                                        <th t-attf-style="color:{{ header or '#1f78ff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12);" class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.order_line" t-as="line">
                                        <tr>
                                            <td><span t-field="line.name"/></td>
                                            <td class="text-end"><span t-field="line.product_uom_qty"/></td>
                                            <td class="text-end"><span t-field="line.price_unit"/></td>
                                            <td class="text-center">
                                                <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                            </td>
                                            <td class="text-end"><strong><span t-field="line.price_subtotal"/></strong></td>
                                        </tr>
                                    </t>
                                    <tr class="total_row" t-attf-style="border-top:3px solid {{header or '#1f78ff'}}">
                                        <td colspan="4" class="text-end"><strong>Total Amount</strong></td>
                                        <td class="text-end total-amount-cell">
                                            <strong><span t-field="doc.amount_total" t-attf-style="color : {{secondary or '#1f78ff'}}"/></strong>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="sale_order_bottom">
                            <table class="structure_table table-borderless">
                                <tr>
                                    <td class="col-7 terms-column">
                                        <h3 class="inv-title-1" t-attf-style="color:{{primary or '#1f78ff'}}">Terms &amp; Conditions</h3>
                                        <div class="terms-text" t-field="doc.note"/>
                                    </td>
                                    <td class="col-5 text-end">
                                        <h3 class="inv-title-1" t-attf-style="color:{{primary or '#1f78ff'}}">Payment Info</h3>
                                        <ul class="list-unstyled payment-info-list">
                                            <li><strong>payment method:</strong> <span t-field="doc.payment_term_id.name"/></li>
                                        </ul>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </t>
</template>

    <template id="report_sale_order_template_8">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_8" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>
