<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_so_custom_6">
        <t t-call="ups_sale_report_template.external_layout_custom">
            <t t-set="primary" t-value="res_company.report_primary_color"/>
            <t t-set="secondary" t-value="res_company.report_secondary_color"/>
            <t t-set="header" t-value="res_company.report_header_color"/>
            <t t-set="r" t-value="int((header or '#8547e8')[1:3], 16)"/>
            <t t-set="g" t-value="int((header or '#8547e8')[3:5], 16)"/>
            <t t-set="b" t-value="int((header or '#8547e8')[5:7], 16)"/>


            <t t-foreach="docs" t-as="doc">
                <div class="page sale_order_6">

                    <div class="invoice-info">
                        <div class="invoice-top">
                            <div class="row">
                                <div class="col-6">
                                    <h4 class="inv-header-1" t-attf-style="color : {{primary or '#8547e8'}}">Order - <span t-field="doc.name"/></h4>

                                </div>
                               <div class="col-6 text-end logo-column">
                                    <div class="invoice-name">
                                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" alt="Logo"/>
                                    </div>
                                    <div class="company-details">
                                        <div class="name" t-field="doc.company_id.name"/>
                                        <div class="location">
                                            <span t-field="doc.company_id.city"/>, 
                                            <span t-if="doc.company_id.state_id" t-field="doc.company_id.state_id.name"/>
                                            <div class="country" t-field="doc.company_id.country_id.name"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr style="background: #ccc; height: 1px; border: 0;"/>
                            <div class="row">
                                <div class="col-4">
                                    <p class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}">Date</p>
                                    <p>Order Date: <span t-field="doc.date_order" t-options='{"widget": "date"}'/></p>
                                    <p t-if="doc.validity_date">Exp. Date: <span t-field="doc.validity_date"/></p>
                                </div>
                                <div class="col-4">
                                    <p class="inv-title-1"
                                    t-attf-style="color: {{ primary or '#8547e8' }};">
                                        Billing Address
                                    </p>
                                    <p t-field="doc.company_id.partner_id"
                                    t-options='{
                                        "widget": "contact",
                                        "fields": ["name", "address"],
                                        "no_marker": True }'/>
                                </div>

                                <div class="col-4 text-end">
                                    <p class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}; text-align: right;">Shipping Address</p>
                                    <p t-field="doc.partner_invoice_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                                </div>
                            </div>
                        </div>

                        <div class="invoice-center" t-attf-style="border-bottom: 3px solid {{secondary or '#8547e8'}};">
                            <table class="table modern-table table-borderless">
                                <thead>
                                    <tr>
                                        <th t-attf-style="background-color:  rgba({{ r }}, {{ g }}, {{ b }}, 0.12); color:  {{header or '#333333'}}">Description</th>
                                        <th class="text-center" t-attf-style="background-color:  rgba({{ r }}, {{ g }}, {{ b }}, 0.12); color:  {{header or '#333333'}}">Price</th>
                                        <th class="text-center" t-attf-style="background-color:  rgba({{ r }}, {{ g }}, {{ b }}, 0.12); color:  {{header or '#333333'}}">Quantity</th>
                                        <th class="text-center" t-attf-style="background-color:  rgba({{ r }}, {{ g }}, {{ b }}, 0.12); color:  {{header or '#333333'}}">Taxes</th>
                                        <th class="text-end" t-attf-style="background-color:  rgba({{ r }}, {{ g }}, {{ b }}, 0.12); color:  {{header or '#333333'}}">Totals</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.order_line" t-as="line">
                                        <tr>
                                            <td>
                                                <div class="item-desc-1">
                                                    <span t-field="line.product_id.name"/>
                                                    <small t-field="line.name"/>
                                                </div>
                                            </td>
                                            <td class="text-center"><span t-field="line.price_unit"/></td>
                                            <td class="text-center"><span t-field="line.product_uom_qty"/></td>
                                            <td class="text-center">
                                               <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                            </td>
                                            <td class="text-end"><span t-field="line.price_subtotal"/></td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <td colspan="4" class="text-end">Subtotal</td>
                                        <td class="text-end"><span t-field="doc.amount_untaxed"/></td>
                                    </tr>
                                    <tr>
                                        <td colspan="4" class="text-end">Tax</td>
                                        <td class="text-end"><span t-field="doc.amount_tax"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="invoice-bottom">
                            <div class="row">
                                <div class="col-6">
                                    <h3 class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}">Payment Info</h3>
                                        <strong>Company:</strong> <span t-field="doc.company_id.name"/><br/>
                                        <strong>Currency:</strong> <span t-field="doc.currency_id.name"/>
                                    <h4 class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}">Payment Terms</h4>
                                    <span class="inv-from-1" t-field="doc.payment_term_id.name"/>
                                </div>
                                <div class="col-6 text-end">
                                    <h3 class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}">Total Amount</h3>
                                    <h1><span t-field="doc.amount_total"/></h1>
                                    <p>Taxes Included</p>
                                </div>
                            </div>
                            <div class="note mt-4">
                                <h3 class="inv-title-1" t-attf-style="color : {{primary or '#8547e8'}}">Terms and Condition</h3>
                                <p class="text-muted" t-field="doc.note"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <template id="report_sale_order_template_6">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_6" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>