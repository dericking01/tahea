<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_so_custom_3">
    <t t-call="ups_sale_report_template.external_layout_custom">
        <t t-set="primary" t-value="res_company.report_primary_color"/>
        <t t-set="secondary" t-value="res_company.report_secondary_color"/>
        <t t-set="header" t-value="res_company.report_header_color"/>
        <t t-set="r" t-value="int((header or '#1e293b')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#1e293b')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#1e293b')[5:7], 16)"/>
        <t t-set="r1" t-value="int((secondary or '#f8fafc')[1:3], 16)"/>
        <t t-set="g1" t-value="int((secondary or '#f8fafc')[3:5], 16)"/>
        <t t-set="b1" t-value="int((secondary or '#f8fafc')[5:7], 16)"/>


        <t t-foreach="docs" t-as="order">
            <div class="page sale_order_3">


               <div class="report_header_container">
    <div class="row align-items-center mb-4">
        <div class="col-6">
            <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" class="main_logo"/>
        </div>
        <div class="col-6 text-end">
            <div class="company_location">
                <strong t-field="res_company.name" class="d-block mb-1"/>
                <span t-field="res_company.city"/>, 
                <span t-if="res_company.state_id" t-field="res_company.state_id.name"/>, 
                <span t-field="res_company.country_id.name"/>
            </div>
        </div>
    </div>

    <div class="row mb-5 mt-2">
        <div class="col-7">
            <h1 class="report-title" t-attf-style="color: {{primary or '#0f172a'}}">SALES ORDER</h1>
            <div t-if="order.state in ['draft', 'sent']" class="status-badge" t-attf-style="background-color: {{primary or '#0f172a'}}; color: #fff;">
                QUOTATION
            </div>
            <div t-if="order.state not in ['draft', 'sent']" class="status-badge confirmed">
                CONFIRMED ORDER
            </div>
        </div>
        <div class="col-5">
            <div class="ref-box" t-attf-style="border-top: 4px solid {{primary or '#0f172a'}}; background-color: #f8fafc;">
                <table class="table-borderless w-100">
                    <tr>
                        <td class="fw-bold text-uppercase">Order id</td>
                        <td class="text-end font-weight-bold"><span t-field="order.name" t-attf-style="color: {{primary or '#0f172a'}}"/></td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-uppercase">Date</td>
                        <td class="text-end"><span t-field="order.date_order" t-options='{"widget": "date"}'/></td>
                    </tr>
                    <tr t-if="order.validity_date">
                        <td class="fw-bold text-uppercase">Expiration</td>
                        <td class="text-end"><span t-field="order.validity_date" t-options='{"widget": "date"}'/></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

               <div class="row mb-5">
                    <div class="col-6 pe-3">
                        <div class="address-card">
                            <div class="card-label" t-attf-style="color: {{secondary or '#64748b'}}; background-color: rgba({{ r1 }}, {{ g1 }}, {{ b1 }}, 0.12); ">Bill To</div>
                             <div class="address-content">
                                <strong t-field="order.company_id.partner_id.name" class="d-block mb-1 fs-16"/>
                                <div t-field="order.company_id.partner_id" 
                                    t-options='{"widget": "contact", "fields": ["address","phone"], "no_marker": False}'/>
                                </div>
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="address-card" t-if="order.partner_shipping_id">
                            <div class="card-label" t-attf-style="color: {{secondary or '#64748b'}}; background-color: rgba({{ r1 }}, {{ g1 }}, {{ b1 }}, 0.12); ">Ship To</div>
                            <div class="address-content">
                                <strong t-field="order.partner_shipping_id.name" class="d-block mb-1 fs-16"/>
                                <div t-field="order.partner_shipping_id" 
                                    t-options='{"widget": "contact", "fields": ["address","phone"], "no_marker": False}'/>
                                </div>
                            </div>
                        </div>
                </div>

                <table class="table-f3 table-borderless">
                    <thead>
                        <tr>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">S No</th>
                            <th style="width: 30%;" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Product / Description</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Quantity</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Unit Price</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Tax</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="order.order_line" t-as="line">
                            <tr t-if="not line.display_type">
                                <td class="text-center"><span t-esc="line_index + 1"/></td>
                                <td>
                                    <div class="fw-bold" t-field="line.product_id.name"/>
                                    <div class="small text-muted" t-field="line.name" t-if="line.name != line.product_id.name"/>
                                </td>
                                <td class="text-center"><span t-esc="int(line.product_uom_qty)"/></td>
                                <td class="text-center">
                                    <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                </td>
                                <td class="text-center">
                                    <span t-out="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                </td>
                                <td class="text-center fw-bold">
                                    <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                </td>
                            </tr>
                            <tr t-if="line.display_type == 'line_section'" class="bg-section">
                                <td colspan="8"><span t-field="line.name"/></td>
                            </tr>
                            <tr t-if="line.display_type == 'line_note'" class="fst-italic">
                                <td colspan="8" class="text-muted"><span t-field="line.name"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

               <div class="row mt-5 align-items-start" style="page-break-inside: avoid;">
                    <div class="col-7 pe-4"> 
                        <div class="terms-section" t-attf-style="background-color: rgba({{ r1 }}, {{ g1 }}, {{ b1 }}, 0.12); border-left: 5px solid {{secondary or '#1e293b;'}}">
                            <p class="mb-2"><strong>Payment Terms:</strong> <span t-field="order.payment_term_id.name"/></p>
                            <p class="mb-2"><strong>Salesperson:</strong> <span t-field="order.user_id.name"/></p>
                            <div t-if="order.note" class="mt-3 small border-top pt-2">
                                <strong>Terms and Condition:</strong>
                                <span t-field="order.note"/>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-5 ps-4">
                        <table class="table-totals table-borderless w-100">
                            <tr>
                                <td class="text-center">Untaxed Amount</td>
                                <td class="text-center"><span t-field="order.amount_untaxed"/></td>
                            </tr>
                            <tr>
                                <td class="text-center">Taxes</td>
                                <td class="text-center"><span t-field="order.amount_tax"/></td>
                            </tr>
                            <tr class="total-final" t-attf-style="color:{{ header or '#ffffff'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">
                                <td class="text-center">TOTAL</td>
                                <td class="text-center"><span t-field="order.amount_total"/></td>
                            </tr>
                        </table>
                    </div>
                </div>
                

            </div>
        </t>
    </t>
</template>
    
<template id="report_sale_order_template_3">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_3" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
