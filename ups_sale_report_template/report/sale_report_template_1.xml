<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="report_so_custom_1">
    <t t-call="ups_sale_report_template.external_layout_custom">
        <t t-set="primary" t-value="res_company.report_primary_color or '' "/>
        <t t-set="secondary" t-value="res_company.report_secondary_color or '' "/>
        <t t-set="header" t-value="res_company.report_header_color or '' "/>
        <t t-set="r" t-value="int((header or '#333333')[1:3], 16)"/>
        <t t-set="g" t-value="int((header or '#333333')[3:5], 16)"/>
        <t t-set="b" t-value="int((header or '#333333')[5:7], 16)"/>

        
        <t t-foreach="docs" t-as="order">
            <div class="page sale_order_1">
            <t t-if="not company" t-set="company" t-value="res_company"/>

               <div class="report_header clearfix" t-attf-style="border-bottom: 3px solid {{primary or '#e91e63'}}">
                    <div class="brand_area">
                        <div class="logo_wrapper">
                            <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" alt="Logo"/>
                        </div>
                        <div class="company_info">
                            <span class="company_name" t-field="res_company.name"/>
                            <div class="company_details">
                                <i class="fa fa-map-marker" style="margin-right: 5px; opacity: 0.7;"/>
                                <span t-field="res_company.city"/>, 
                                <span t-if="res_company.state_id" t-field="res_company.state_id.name"/>, 
                                <span t-field="res_company.country_id.name"/>
                            </div>
                        </div>
                    </div>

                    <div class="doc_info">
                        <h2 t-attf-style="color: {{ primary or '#e91e63'}};">SALES ORDER</h2>
                        <div class="order_pill" t-attf-style="background-color: {{primary or '#e91e63'}}">
                            <span class="order_number">#<span t-field="order.name"/></span>
                        </div>
                    </div>
                </div>

                <div class="meta_grid">
                    <div class="meta_item">
                        <label>Date</label>
                        <span t-field="order.date_order" t-options='{"widget": "date"}'/>
                    </div>
                    <div class="meta_item">
                        <label>Expiration</label>
                        <span t-field="order.validity_date" t-options='{"widget": "date"}'/>
                    </div>
                    <div class="meta_item">
                        <label>Salesperson</label>
                        <span t-field="order.user_id.name"/>
                    </div>
                    <div class="meta_item">
                        <label>Payment Terms</label>
                        <span t-field="order.payment_term_id.name"/>
                    </div>
                </div>

                <div class="address_container clearfix">
                    <div class="address_card bill_to">
                        <span class="addr_label" t-attf-style="color: {{ primary or '#e91e63'}};">Bill To</span>
                        <span class="partner_name" t-field="order.partner_id.name"/>
                        <div t-field="order.partner_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    </div>
                    <div class="address_card ship_to">
                        <span class="addr_label" t-attf-style="color: {{ primary or '#e91e63'}};">Ship To</span>
                        <span class="partner_name" t-field="order.partner_shipping_id.name"/>
                        <div t-field="order.partner_shipping_id" t-options='{"widget": "contact", "fields": ["address"], "no_marker": True}'/>
                    </div>
                </div>

              <table class="custom_table_modern  table-borderless mt-4">
                    <thead>
                        <tr>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">S NO</th>
                            <th class="text-left" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Product</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Ordered</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Unit Price</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Taxes</th>
                            <th class="text-center" t-attf-style="color:{{ header or '#333333'}}; background-color: rgba({{ r }}, {{ g }}, {{ b }}, 0.12); ">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="order.order_line" t-as="line">
                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                
                                <t t-if="not line.display_type">
                                    <td class="text-center">
                                        <span t-esc="line_index + 1"/>
                                    </td>
                                    <td>
                                        <div class="prod_name" t-field="line.product_id.name" style="font-weight: bold;"/>
                                        <div class="prod_desc" t-field="line.name" t-if="line.name != line.product_id.name"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-esc="int(line.product_uom_qty)"/> 
                                        <small t-field="line.product_uom"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.price_unit"/>
                                    </td>
                                     <td class="text-center">
                                        <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                    </td>
                                    <td class="text-center font-weight-bold">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/>
                                    </td>
                                </t>

                                <t t-if="line.display_type">
                                    <td colspan="8">
                                        <span t-field="line.name"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>


                <div class="footer_container clearfix">
                    <div class="notes_section">
                        <span class="notes_label">Terms &amp; Notes</span>
                        <div t-field="order.note"/>
                    </div>
                    <div class="totals_section">
                        <div class="total_row">
                            <span>Subtotal</span>
                            <span t-field="order.amount_untaxed"/>
                        </div>
                        <div class="total_row">
                            <span>Taxes</span>
                            <span t-field="order.amount_tax"/>
                        </div>
                        <div class="total_row grand_total" t-attf-style="color: {{ secondary or '#e91e63'}};">
                            <span t-attf-style="color: {{ secondary or '#e91e63'}};">TOTAL</span>
                            <span t-field="order.amount_total" t-attf-style="color: {{ secondary or '#e91e63'}};"/>
                        </div>
                    </div>
                </div>

            </div>
        </t>
    </t>
</template>

    <template id="report_sale_order_template_1">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="ups_sale_report_template.report_so_custom_1" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>



    
</odoo>